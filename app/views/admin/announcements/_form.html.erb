<%= form_with model: announcement,
    url: announcement.persisted? ? admin_announcement_path(announcement) : admin_announcements_path,
    method: announcement.persisted? ? :patch : :post,
    class: "space-y-6" do |f| %>
  <%= render "shared/form_errors", object: announcement %>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 space-y-5">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        Message <span class="text-red-500">*</span>
      </label>
      <%= f.text_area :message, rows: 5,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
          placeholder: "Write the announcement customers will see…" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Show From <span class="text-red-500">*</span>
        </label>
        <%= f.datetime_local_field :starts_at,
            value: announcement.starts_at&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Show Until <span class="text-red-500">*</span>
        </label>
        <%= f.datetime_local_field :ends_at,
            value: announcement.ends_at&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.check_box :active, class: "w-4 h-4 rounded border-gray-300 text-amber-700 focus:ring-amber-500" %>
      <label class="text-sm font-medium text-gray-700">Active (visible to customers when within date range)</label>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "bg-amber-800 text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-amber-900 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_announcements_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
<% end %>
