<% content_for :title, "Announcements — Admin" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Announcements</h1>
  <%= link_to "New Announcement", new_admin_announcement_path,
      class: "inline-flex items-center gap-2 bg-amber-800 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-amber-900 transition-colors" %>
</div>

<% if @announcements.empty? %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center text-gray-400 text-sm">
    No announcements yet. Create one to show a message to visitors.
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Message</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">From</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Until</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 w-28"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @announcements.each do |a| %>
          <% now = Time.current %>
          <% live = a.active? && a.starts_at <= now && a.ends_at >= now %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-sm text-gray-900 max-w-sm">
              <p class="truncate"><%= a.message %></p>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">
              <%= a.starts_at.strftime("%b %-d, %Y %-I:%M %p") %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">
              <%= a.ends_at.strftime("%b %-d, %Y %-I:%M %p") %>
            </td>
            <td class="px-6 py-4">
              <% if live %>
                <span class="inline-flex items-center gap-1.5 text-xs font-medium text-green-700 bg-green-50 px-2.5 py-1 rounded-full">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  Live
                </span>
              <% elsif !a.active? %>
                <span class="text-xs font-medium text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full">Inactive</span>
              <% elsif now < a.starts_at %>
                <span class="text-xs font-medium text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">Scheduled</span>
              <% else %>
                <span class="text-xs font-medium text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full">Expired</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Edit", edit_admin_announcement_path(a),
                    class: "text-sm text-amber-700 hover:text-amber-900 font-medium" %>
                <%= button_to "Delete", admin_announcement_path(a), method: :delete,
                    form: { class: "contents" },
                    data: { turbo_confirm: "Delete this announcement?" },
                    class: "text-sm text-red-500 hover:text-red-700 font-medium" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
