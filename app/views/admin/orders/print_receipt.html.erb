<% content_for :title, "Receipt — #{@order.order_number}" %>

<div style="max-width: 680px; margin: 0 auto; padding: 40px 24px;">

  <!-- Print / Close buttons -->
  <div class="no-print" style="display:flex; justify-content:flex-end; gap:8px; margin-bottom:24px;">
    <a href="<%= admin_order_path(@order) %>"
       style="font-size:13px; padding:8px 16px; border:1px solid #d1d5db; border-radius:6px; text-decoration:none; color:#374151;">
      ← Back
    </a>
    <button onclick="window.print()"
            style="font-size:13px; padding:8px 16px; background:#78350f; color:#fff; border:none; border-radius:6px; cursor:pointer;">
      Print Receipt
    </button>
  </div>

  <!-- Header -->
  <div style="text-align:center; border-bottom:2px solid #e5e7eb; padding-bottom:24px; margin-bottom:24px;">
    <p style="font-size:22px; font-weight:700; color:#1c1917; margin:0 0 4px;">Warehouse Furniture</p>
    <p style="font-size:12px; color:#6b7280; margin:0;">1104 E Veterans Memorial Blvd, Killeen, TX 76541</p>
    <p style="font-size:12px; color:#6b7280; margin:4px 0 0;">(254) 628-9088</p>
  </div>

  <!-- Order meta -->
  <div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
    <div>
      <p style="font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; margin:0 0 2px;">Order Number</p>
      <p style="font-size:16px; font-weight:700; font-family:monospace; margin:0;"><%= @order.order_number %></p>
    </div>
    <div style="text-align:right;">
      <p style="font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; margin:0 0 2px;">Date</p>
      <p style="font-size:14px; margin:0;"><%= @order.created_at.strftime("%B %d, %Y") %></p>
      <p style="font-size:12px; color:#6b7280; margin:2px 0 0;"><%= @order.created_at.strftime("%l:%M %p") %></p>
    </div>
  </div>

  <!-- Customer + Address -->
  <div style="display:flex; gap:32px; flex-wrap:wrap; margin-bottom:24px; padding:16px; background:#f9fafb; border-radius:8px;">
    <div>
      <p style="font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; margin:0 0 6px;">Customer</p>
      <p style="font-size:14px; font-weight:600; margin:0 0 2px;"><%= @order.customer_name %></p>
      <p style="font-size:13px; color:#374151; margin:0 0 2px;"><%= @order.customer_email %></p>
      <% if @order.customer_phone.present? %>
        <p style="font-size:13px; color:#374151; margin:0;"><%= @order.customer_phone %></p>
      <% end %>
    </div>
    <div>
      <p style="font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; margin:0 0 6px;">Delivery Address</p>
      <p style="font-size:14px; font-weight:600; margin:0 0 2px;"><%= @order.shipping_address["full_name"] %></p>
      <p style="font-size:13px; color:#374151; margin:0 0 2px;"><%= @order.shipping_address["street_address"] %></p>
      <p style="font-size:13px; color:#374151; margin:0;"><%= @order.shipping_address["city"] %>, <%= @order.shipping_address["state"] %> <%= @order.shipping_address["zip_code"] %></p>
    </div>
  </div>

  <!-- Items table -->
  <table style="width:100%; border-collapse:collapse; margin-bottom:0; font-size:13px;">
    <thead>
      <tr style="border-bottom:2px solid #e5e7eb;">
        <th style="text-align:left; padding:8px 6px 8px 0; font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; font-weight:600;">Item</th>
        <th style="text-align:center; padding:8px 6px; font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; font-weight:600; white-space:nowrap;">Qty</th>
        <th style="text-align:right; padding:8px 6px; font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; font-weight:600; white-space:nowrap;">Unit Price</th>
        <th style="text-align:right; padding:8px 0 8px 6px; font-size:11px; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; font-weight:600; white-space:nowrap;">Total</th>
      </tr>
    </thead>
    <tbody>
      <% @order_items.each do |item| %>
        <tr style="border-bottom:1px solid #f3f4f6;">
          <td style="padding:10px 6px 10px 0;">
            <p style="font-weight:600; margin:0 0 2px;"><%= item.product_name %></p>
            <p style="font-size:11px; color:#9ca3af; font-family:monospace; margin:0;">SKU: <%= item.product_sku %></p>
          </td>
          <td style="text-align:center; padding:10px 6px;"><%= item.quantity %></td>
          <td style="text-align:right; padding:10px 6px;"><%= number_to_currency(item.unit_price) %></td>
          <td style="text-align:right; padding:10px 0 10px 6px; font-weight:600;"><%= number_to_currency(item.line_total) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <!-- Totals -->
  <div style="margin-top:4px; border-top:2px solid #e5e7eb; padding-top:12px;">
    <div style="max-width:260px; margin-left:auto;">
      <div style="display:flex; justify-content:space-between; padding:4px 0; font-size:13px; color:#6b7280;">
        <span>Subtotal</span>
        <span><%= number_to_currency(@order.subtotal) %></span>
      </div>
      <div style="display:flex; justify-content:space-between; padding:4px 0; font-size:13px; color:#6b7280;">
        <span>Shipping</span>
        <span><%= number_to_currency(@order.shipping_amount) %></span>
      </div>
      <% if @order.tax_amount > 0 %>
        <div style="display:flex; justify-content:space-between; padding:4px 0; font-size:13px; color:#6b7280;">
          <span>Tax</span>
          <span><%= number_to_currency(@order.tax_amount) %></span>
        </div>
      <% end %>
      <% if @order.discount_amount > 0 %>
        <div style="display:flex; justify-content:space-between; padding:4px 0; font-size:13px; color:#6b7280;">
          <span>Discount</span>
          <span>-<%= number_to_currency(@order.discount_amount) %></span>
        </div>
      <% end %>
      <div style="display:flex; justify-content:space-between; padding:10px 0 4px; font-size:16px; font-weight:700; border-top:1px solid #e5e7eb; margin-top:6px;">
        <span>Total</span>
        <span><%= number_to_currency(@order.grand_total) %></span>
      </div>
    </div>
  </div>

  <!-- Payment + Status -->
  <div style="margin-top:20px; padding:12px 16px; border:1px solid #e5e7eb; border-radius:8px; font-size:13px; color:#374151;">
    <span style="font-weight:600;">Status:</span> <%= @order.status.humanize %>
    &nbsp;·&nbsp;
    <span style="font-weight:600;">Payment:</span> <%= @order.payment_method.humanize %>
    <% if @order.external_payment_reference.present? %>
      &nbsp;·&nbsp;<span style="font-weight:600;">Ref:</span> <%= @order.external_payment_reference %>
    <% end %>
  </div>

  <% if @order.notes.present? %>
    <div style="margin-top:16px; font-size:13px; color:#6b7280;">
      <span style="font-weight:600; color:#374151;">Notes:</span> <%= @order.notes %>
    </div>
  <% end %>

  <!-- Footer -->
  <div style="margin-top:40px; text-align:center; font-size:12px; color:#9ca3af; border-top:1px solid #f3f4f6; padding-top:20px;">
    <p style="margin:0 0 4px;">Thank you for choosing Warehouse Furniture!</p>
    <p style="margin:0;">Questions? Contact us at (254) 628-9088</p>
  </div>

</div>
