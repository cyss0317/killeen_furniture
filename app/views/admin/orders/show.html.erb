<% content_for :title, "Order #{@order.order_number}" %>

<div class="flex items-center justify-between mb-6 flex-wrap gap-3">
  <div class="flex items-center gap-4 flex-wrap">
    <%= link_to "← Orders", admin_orders_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-bold text-gray-900 font-mono"><%= @order.order_number %></h1>
    <span class="px-3 py-1 rounded-full text-sm font-medium <%= status_badge_class(@order.status) %>">
      <%= @order.status.humanize %>
    </span>
    <% if @order.source != "web_customer" %>
      <span class="px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">
        <%= @order.source.humanize %>
      </span>
    <% end %>
  </div>

  <!-- Receipt Actions -->
  <div class="flex items-center gap-2">
    <%= link_to print_receipt_admin_order_path(@order), target: "_blank",
        class: "inline-flex items-center gap-1.5 text-sm px-3 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
      </svg>
      Print Receipt
    <% end %>
    <%= button_to resend_confirmation_admin_order_path(@order), method: :post,
        form: { data: { turbo_confirm: "Resend confirmation email to #{@order.customer_email}?" } },
        class: "inline-flex items-center gap-1.5 text-sm px-3 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      Resend Email
    <% end %>
  </div>

  <!-- Status Update -->
  <% if @order.editable_by_admin? && @order.allowed_next_statuses.any? %>
    <%= form_with url: update_status_admin_order_path(@order), method: :patch, class: "flex gap-2 items-center" do |f| %>
      <%
        current_label = "#{@order.status.humanize} ✦ current"
        next_options  = @order.allowed_next_statuses.map { |s| [s.to_s.humanize, s] }
        all_options   = [[current_label, @order.status]] + next_options
      %>
      <%= f.select :status,
          options_for_select(all_options, @order.status),
          {},
          class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
          data: { current: @order.status },
          onchange: "this.nextElementSibling.disabled = (this.value === this.dataset.current)" %>
      <%= f.submit "Update Status",
          disabled: true,
          class: "bg-amber-800 text-white text-sm px-4 py-2 rounded-md hover:bg-amber-900 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed" %>
    <% end %>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Order Items -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h2 class="font-semibold text-gray-900">Order Items</h2>
        <% if @order.pending? %>
          <%= link_to edit_admin_order_path(@order),
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-amber-800 bg-amber-50 border border-amber-200 rounded-md hover:bg-amber-100 transition-colors" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit Order
          <% end %>
        <% end %>
      </div>
      <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-100">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Qty</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Sell Price</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Margin</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @order_items.each do |item| %>
            <% othumb = item.product&.vendor_image_urls&.first %>
            <tr>
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if othumb %>
                    <div class="relative group shrink-0">
                      <img src="<%= othumb %>" alt="<%= item.product_name %>"
                           class="w-10 h-10 rounded-md object-cover bg-gray-100 cursor-pointer ring-1 ring-gray-200">
                      <div class="pointer-events-none absolute left-full top-1/2 -translate-y-1/2 ml-2 z-50
                                  opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                        <div class="w-64 h-64 rounded-lg bg-white shadow-xl ring-2 ring-gray-200 p-1 flex items-center justify-center">
                          <img src="<%= othumb %>" alt="<%= item.product_name %>"
                               class="max-w-full max-h-full object-contain rounded-md">
                        </div>
                        <div class="absolute -left-1.5 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rotate-45 shadow ring-1 ring-gray-200"></div>
                      </div>
                    </div>
                  <% else %>
                    <div class="w-10 h-10 rounded-md bg-gray-100 ring-1 ring-gray-200 flex items-center justify-center shrink-0">
                      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                      </svg>
                    </div>
                  <% end %>
                  <div>
                    <% if item.product %>
                      <%= link_to item.product_name, admin_product_path(item.product),
                            class: "text-sm font-medium text-amber-800 hover:underline" %>
                    <% else %>
                      <p class="text-sm font-medium text-gray-900"><%= item.product_name %></p>
                    <% end %>
                    <p class="text-xs text-gray-400 font-mono">SKU: <%= item.product_sku %></p>

                <% payload = item.product&.ashley_payload.presence %>
                <% if payload %>
                  <%# ── Inline attribute chips ── %>
                  <% chip_pairs = [
                      ["Style",    payload["style"]],
                      ["Color",    item.product.color.presence || payload["color"]],
                      ["Showroom", payload["showroom"]],
                      ["Division", payload["division"]],
                      ["Status",   payload["status"]],
                    ].select { |_, v| v.present? } %>

                  <% if chip_pairs.any? %>
                    <div class="flex flex-wrap gap-1 mt-1.5">
                      <% chip_pairs.each do |label, value| %>
                        <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs bg-gray-100 text-gray-600">
                          <span class="font-medium text-gray-400"><%= label %>:</span> <%= value %>
                        </span>
                      <% end %>
                    </div>
                  <% end %>

                  <%# ── Ship-by date ── %>
                  <% if payload["ship_by"].present? %>
                    <p class="text-xs text-blue-600 mt-1">
                      Ships by <%= payload["ship_by"] %>
                    </p>
                  <% end %>

                  <%# ── Extra dimensions collapsible ── %>
                  <% extra = payload["extra_dimensions"].presence %>
                  <% if extra.present? %>
                    <details class="mt-1.5">
                      <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600 select-none">
                        More dimensions
                      </summary>
                      <dl class="mt-1 space-y-0.5">
                        <% extra.each do |label, value| %>
                          <div class="flex gap-1 text-xs text-gray-500">
                            <dt class="font-medium text-gray-400 whitespace-nowrap"><%= label %>:</dt>
                            <dd><%= value %></dd>
                          </div>
                        <% end %>
                      </dl>
                    </details>
                  <% end %>
                <% end %>
                  </div><%# close text wrapper %>
                </div><%# close flex row %>
              </td>
              <td class="px-6 py-4 text-center text-sm"><%= item.quantity %></td>
              <td class="px-6 py-4 text-right text-sm"><%= number_to_currency(item.unit_price) %></td>
              <td class="px-6 py-4 text-right text-sm">
                <% if item.margin %>
                  <span data-controller="peekable" class="inline-flex flex-col items-end gap-0.5">
                    <span class="inline-flex items-center gap-1">
                      <button type="button" data-action="click->peekable#toggle"
                              class="text-gray-400 hover:text-gray-600 focus:outline-none cursor-pointer flex items-center justify-center" title="Show margin">
                        <%# Eye open (shown when hidden) %>
                        <svg data-peekable-target="eyeOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                        <%# Eye off (shown when revealed) %>
                        <svg data-peekable-target="eyeOff" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.966 9.966 0 012.122-3.368M6.53 6.53A9.956 9.956 0 0112 5c4.477 0 8.268 2.943 9.542 7a9.978 9.978 0 01-4.512 5.478M6.53 6.53L3 3m3.53 3.53l11.94 11.94M3 3l18 18"/>
                        </svg>
                      </button>
                      <span data-peekable-target="value" class="hidden text-green-600 font-medium">
                        <%= number_to_currency(item.margin) %>
                      </span>
                    </span>
                    <% if item.margin_percentage %>
                      <span data-peekable-target="value" class="hidden text-xs text-green-500">
                        (<%= item.margin_percentage %>%)
                      </span>
                    <% end %>
                  </span>
                <% else %>
                  <span class="text-gray-400">—</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right text-sm font-semibold"><%= number_to_currency(item.line_total) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>

      <div class="px-6 py-4 border-t border-gray-100 space-y-1">
        <div class="flex justify-between text-sm text-gray-600">
          <span>Subtotal</span>
          <span><%= number_to_currency(@order.subtotal) %></span>
        </div>
        <div class="flex justify-between text-sm text-gray-600">
          <span>Shipping</span>
          <span><%= number_to_currency(@order.shipping_amount) %></span>
        </div>
        <% if @order.tax_amount > 0 %>
          <div class="flex justify-between text-sm text-gray-600">
            <span>Tax</span>
            <span><%= number_to_currency(@order.tax_amount) %></span>
          </div>
        <% end %>
        <div class="flex justify-between text-base font-bold border-t border-gray-200 pt-2 mt-2">
          <span>Grand Total</span>
          <span><%= number_to_currency(@order.grand_total) %></span>
        </div>
        <% order_cogs = @order_items.sum { |i| i.unit_cost.to_f * i.quantity } %>
        <% if order_cogs > 0 %>
          <% order_profit = @order.subtotal - order_cogs %>
          <% profit_pct   = (order_profit / order_cogs * 100).round(1) %>
          <div class="border-t border-gray-100 pt-2 mt-2 space-y-1">
            <div class="flex justify-between text-sm text-gray-500">
              <span>Total Cost (COGS)</span>
              <span><%= number_to_currency(order_cogs) %></span>
            </div>
            <div class="flex justify-between text-sm font-semibold text-green-700" data-controller="peekable">
              <span>Gross Profit</span>
              <span class="inline-flex items-center gap-1.5">
                <button type="button" data-action="click->peekable#toggle"
                        class="text-green-500 hover:text-green-700 focus:outline-none cursor-pointer flex items-center justify-center" title="Show gross profit">
                  <svg data-peekable-target="eyeOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  <svg data-peekable-target="eyeOff" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                          d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.966 9.966 0 012.122-3.368M6.53 6.53A9.956 9.956 0 0112 5c4.477 0 8.268 2.943 9.542 7a9.978 9.978 0 01-4.512 5.478M6.53 6.53L3 3m3.53 3.53l11.94 11.94M3 3l18 18"/>
                  </svg>
                </button>
                <span data-peekable-target="value" class="hidden">
                  <%= number_to_currency(order_profit) %> (<%= profit_pct %>%)
                </span>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Delivery Events Timeline %>
    <% if @delivery_events.any? %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h2 class="font-semibold text-gray-900 mb-4">Delivery Timeline</h2>
        <ol class="relative border-l border-gray-200 ml-3">
          <% @delivery_events.each do |event| %>
            <li class="mb-6 ml-6">
              <span class="absolute -left-3 flex items-center justify-center w-6 h-6 rounded-full
                <%= event.delivered? ? 'bg-green-100 ring-2 ring-green-500' : 'bg-gray-100 ring-2 ring-gray-300' %>">
                <% if event.delivered? %>
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <% else %>
                  <svg class="w-3 h-3 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="5"/></svg>
                <% end %>
              </span>
              <div class="ml-1">
                <p class="text-sm font-medium text-gray-900"><%= event.status.humanize %></p>
                <% if event.note.present? %>
                  <p class="text-xs text-gray-500 mt-0.5"><%= event.note %></p>
                <% end %>
                <time class="text-xs text-gray-400">
                  <%= event.created_at.strftime("%b %d, %Y %l:%M %p") %>
                  <% if event.created_by %>
                    · by <%= event.created_by.full_name %>
                  <% end %>
                </time>
              </div>
            </li>
          <% end %>
        </ol>
      </div>
    <% end %>
  </div>

  <!-- Sidebar Info -->
  <div class="space-y-6">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h3 class="font-semibold text-gray-900 mb-4">Order Info</h3>
      <dl class="space-y-2 text-sm">
        <div>
          <dt class="text-gray-500">Placed</dt>
          <dd><%= @order.created_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Source</dt>
          <dd><%= @order.source.humanize %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Salesperson</dt>
          <dd class="font-medium"><%= @order.salesperson&.full_name || "—" %></dd>
        </div>
        <% if @order.stripe_payment_intent_id.present? %>
          <div>
            <dt class="text-gray-500">Stripe ID</dt>
            <dd class="font-mono text-xs truncate"><%= @order.stripe_payment_intent_id %></dd>
          </div>
        <% end %>
        <% if @order.notes.present? %>
          <div>
            <dt class="text-gray-500">Notes</dt>
            <dd class="text-gray-700 mt-1"><%= @order.notes %></dd>
          </div>
        <% end %>
      </dl>
    </div>
    
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6" id="customer-card-<%= @order.id %>">
      <%# ── View mode ── %>
      <div id="customer-view-<%= @order.id %>">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900">Customer</h3>
          <button type="button"
                  onclick="document.getElementById('customer-view-<%= @order.id %>').classList.add('hidden'); document.getElementById('customer-edit-<%= @order.id %>').classList.remove('hidden')"
                  class="text-xs text-amber-700 hover:text-amber-900 font-medium flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
            Edit
          </button>
        </div>
        <dl class="space-y-2 text-sm">
          <div>
            <dt class="text-gray-500">Name</dt>
            <dd class="font-medium"><%= @order.customer_name %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Email</dt>
            <dd><%= mail_to @order.customer_email, @order.customer_email, class: "text-amber-700 hover:underline" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Phone</dt>
            <dd><%= @order.customer_phone.presence || "—" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Account</dt>
            <dd>
              <% if @order.user %>
                <span class="text-green-600 text-xs font-medium">Registered User</span>
              <% else %>
                <span class="text-gray-400 text-xs">Guest</span>
              <% end %>
            </dd>
          </div>
        </dl>
      </div>

      <%# ── Edit mode ── %>
      <div id="customer-edit-<%= @order.id %>" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900">Edit Customer</h3>
          <button type="button"
                  onclick="document.getElementById('customer-view-<%= @order.id %>').classList.remove('hidden'); document.getElementById('customer-edit-<%= @order.id %>').classList.add('hidden')"
                  class="text-xs text-gray-400 hover:text-gray-600 font-medium">
            Cancel
          </button>
        </div>

        <% if @order.user %>
          <p class="text-xs text-gray-400 bg-gray-50 rounded px-2 py-1.5 mb-3">
            Registered user account. Filling these fields overrides contact info for this order only.
          </p>
        <% end %>

        <%= form_with url: update_customer_admin_order_path(@order), method: :patch, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
            <%= text_field_tag :guest_name, @order.customer_name,
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                placeholder: "Full name" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Email <span class="text-red-500">*</span></label>
            <%= email_field_tag :guest_email, @order.customer_email,
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                placeholder: "email@example.com" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Phone</label>
            <%= telephone_field_tag :guest_phone, @order.customer_phone,
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                placeholder: "(254) 555-0100" %>
          </div>
          <div class="flex gap-2 pt-1">
            <%= f.submit "Save Changes",
                class: "flex-1 bg-amber-800 text-white text-sm py-2 px-4 rounded-md hover:bg-amber-900 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <%# ── View mode ── %>
      <div id="address-view-<%= @order.id %>">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900">Delivery Address</h3>
          <button type="button"
                  onclick="document.getElementById('address-view-<%= @order.id %>').classList.add('hidden'); document.getElementById('address-edit-<%= @order.id %>').classList.remove('hidden')"
                  class="text-xs text-amber-700 hover:text-amber-900 font-medium flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
            Edit
          </button>
        </div>
        <address class="text-sm text-gray-600 not-italic">
          <strong><%= @order.shipping_address["full_name"] %></strong><br>
          <%= @order.shipping_address["street_address"] %><br>
          <%= @order.shipping_address["city"] %>, <%= @order.shipping_address["state"] %>
          <%= @order.shipping_address["zip_code"] %>
        </address>
        <% if @order.delivery_zone %>
          <p class="text-xs text-gray-400 mt-2">Zone: <%= @order.delivery_zone.name %></p>
        <% end %>
      </div>

      <%# ── Edit mode ── %>
      <div id="address-edit-<%= @order.id %>" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900">Edit Address</h3>
          <button type="button"
                  onclick="document.getElementById('address-view-<%= @order.id %>').classList.remove('hidden'); document.getElementById('address-edit-<%= @order.id %>').classList.add('hidden')"
                  class="text-xs text-gray-400 hover:text-gray-600 font-medium">
            Cancel
          </button>
        </div>
        <%= form_with url: update_address_admin_order_path(@order), method: :patch, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Full Name <span class="text-red-500">*</span></label>
            <%= text_field_tag :full_name, @order.shipping_address["full_name"],
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                placeholder: "Recipient name" %>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Street Address <span class="text-red-500">*</span></label>
            <%= text_field_tag :street_address, @order.shipping_address["street_address"],
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                placeholder: "123 Main St" %>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">City <span class="text-red-500">*</span></label>
              <%= text_field_tag :city, @order.shipping_address["city"],
                  class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">State <span class="text-red-500">*</span></label>
              <%= text_field_tag :state, @order.shipping_address["state"],
                  class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                  placeholder: "TX" %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">ZIP Code <span class="text-red-500">*</span></label>
            <%= text_field_tag :zip_code, @order.shipping_address["zip_code"],
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500",
                placeholder: "76541" %>
          </div>
          <%= f.submit "Save Address",
              class: "w-full bg-amber-800 text-white text-sm py-2 px-4 rounded-md hover:bg-amber-900 cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <%# Commission Assignment (admin+, not shown for canceled/refunded orders) %>
    <% if policy(@order).assign_commission? && !@order.canceled? && !@order.refunded? %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-3">Assign Commission</h3>
        <% if @order.salesperson.present? %>
          <p class="text-sm text-gray-600 mb-3">
            Currently assigned to:
            <strong class="text-gray-900"><%= @order.salesperson.full_name %></strong>
          </p>
        <% end %>
        <%= form_with url: assign_commission_admin_order_path(@order), method: :patch, class: "space-y-3" do |f| %>
          <%= f.select :salesperson_id,
              options_for_select(
                [["— None —", ""]] + @salespeople.map { |u| [u.full_name, u.id] },
                @order.salesperson_id
              ),
              {},
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          <%= f.submit "Save", class: "w-full bg-amber-800 text-white text-sm py-2 px-4 rounded-md hover:bg-amber-900 cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <%# Delivery Assignment (super_admin only, not shown for canceled/refunded orders) %>
    <% if policy(@order).assign? && !@order.canceled? && !@order.refunded? %>
      <div class="bg-white rounded-lg shadow-sm border border-amber-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-3">Assign Delivery</h3>
        <% if @order.assigned_to %>
          <p class="text-sm text-gray-600 mb-3">
            Currently assigned to:
            <strong class="text-gray-900"><%= @order.assigned_to.full_name %></strong>
          </p>
        <% end %>
        <% if @delivery_admins.any? %>
          <%= form_with url: assign_delivery_admin_order_path(@order), method: :patch, class: "space-y-3" do |f| %>
            <%= f.select :assigned_to_id,
                options_for_select(@delivery_admins.map { |u| [u.full_name, u.id] }, @order.assigned_to_id),
                { include_blank: "Select delivery admin" },
                class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            <%= f.submit "Assign", class: "w-full bg-amber-800 text-white text-sm py-2 px-4 rounded-md hover:bg-amber-900 cursor-pointer" %>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400 italic">No delivery admins available. Create a user with admin role + delivery kind first.</p>
        <% end %>
      </div>
    <% end %>

    <%# Current delivery status if assigned %>
    <% if @order.assigned_to && !policy(@order).assign? %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-2">Assigned To</h3>
        <p class="text-sm text-gray-700"><%= @order.assigned_to.full_name %></p>
        <% if @order.delivered_at %>
          <p class="text-sm text-green-600 mt-1">
            Delivered <%= @order.delivered_at.strftime("%b %d, %Y %l:%M %p") %>
          </p>
          <% if @order.delivered_by %>
            <p class="text-xs text-gray-400">by <%= @order.delivered_by.full_name %></p>
          <% end %>
        <% end %>
      </div>
    <% end %>

  </div>
</div>

<% content_for :help_content do %>
  <div>
    <p class="font-semibold text-gray-900 mb-1">Order Detail</p>
    <p class="text-gray-500 text-xs">Full view of a single order — items, customer, address, and delivery.</p>
  </div>
  <div class="space-y-3">
    <div class="border-l-2 border-amber-400 pl-3">
      <p class="font-medium text-gray-800">Update Status</p>
      <p class="text-gray-500 text-xs mt-0.5">Use the dropdown at the top to advance the order through the workflow. Each status change is logged.</p>
    </div>
    <div class="border-l-2 border-amber-400 pl-3">
      <p class="font-medium text-gray-800">Margin (Eye Icon)</p>
      <p class="text-gray-500 text-xs mt-0.5">Click the eye icon in the Margin column to reveal profit per item. The gross profit total is hidden at the bottom for privacy.</p>
    </div>
    <div class="border-l-2 border-amber-400 pl-3">
      <p class="font-medium text-gray-800">Edit Customer & Address</p>
      <p class="text-gray-500 text-xs mt-0.5">Click the Edit button next to Customer or Delivery Address to correct details without cancelling the order.</p>
    </div>
    <div class="border-l-2 border-amber-400 pl-3">
      <p class="font-medium text-gray-800">Assign Delivery</p>
      <p class="text-gray-500 text-xs mt-0.5">Super admins can assign the order to a delivery staff member. The staff member then sees it in the Delivery Portal.</p>
    </div>
    <div class="border-l-2 border-amber-400 pl-3">
      <p class="font-medium text-gray-800">Resend Confirmation</p>
      <p class="text-gray-500 text-xs mt-0.5">Resends the order confirmation email to the customer. Useful if the original was missed or went to spam.</p>
    </div>
  </div>
<% end %>
