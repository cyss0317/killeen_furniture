<% content_for :title, @product.name %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-4">
    <%= link_to "← Products", admin_products_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-bold text-gray-900"><%= @product.name %></h1>
    <% status_class = @product.published? ? 'bg-green-100 text-green-700' : @product.draft? ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600' %>
    <span class="px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_class %>">
      <%= @product.status.humanize %>
    </span>
  </div>
  <div class="flex gap-2">
    <% if @product.brand.to_s.match?(/ashley/i) %>
      <%= button_to "↻ Fetch Ashley Data", refetch_ashley_admin_product_path(@product), method: :post,
          class: "px-4 py-2 text-sm font-medium border border-amber-300 text-amber-800 rounded-md hover:bg-amber-50 transition-colors cursor-pointer" %>
    <% end %>
    <%= link_to "Edit", edit_admin_product_path(@product), class: "px-4 py-2 text-sm font-medium border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
    <% if @product.draft? || @product.archived? %>
      <%= button_to "Publish", publish_admin_product_path(@product), method: :patch,
          class: "px-4 py-2 text-sm font-medium bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Images -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h3 class="font-semibold text-gray-900 mb-3">Images</h3>

      <% if @product.vendor_image_urls.present? %>
        <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
          Vendor Images (<%= @product.vendor_image_urls.size %>)
        </h4>
        <div class="grid grid-cols-3 sm:grid-cols-4 gap-3 mb-4">
          <% @product.vendor_image_urls.each_with_index do |url, i| %>
            <a href="<%= url %>" target="_blank" rel="noopener"
               class="block aspect-square rounded-md overflow-hidden bg-gray-100 ring-1 ring-gray-200 hover:ring-amber-400 transition-all">
              <img src="<%= url %>" alt="<%= @product.name %> — image <%= i + 1 %>"
                   loading="lazy"
                   class="w-full h-full object-cover"
                   onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.outerHTML='<span class=\'text-xs text-gray-400 text-center px-1\'>Failed to load</span>'">
            </a>
          <% end %>
        </div>
      <% end %>

      <% if @product.images.attached? %>
        <% if @product.vendor_image_urls.present? %>
          <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Uploaded Images</h4>
        <% end %>
        <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
          <% @product.images.each do |img| %>
            <div class="aspect-square rounded-md overflow-hidden bg-gray-100 ring-1 ring-gray-200">
              <%= image_tag img.variant(resize_to_fill: [120, 120]), class: "w-full h-full object-cover" %>
            </div>
          <% end %>
        </div>
      <% end %>
      <% unless @product.vendor_image_urls.present? || @product.images.attached? %>
        <p class="text-sm text-gray-400">No images. <%= link_to "Edit product", edit_admin_product_path(@product), class: "text-amber-700 hover:underline" %> to add images.</p>
      <% end %>

      <%# Product video — pick the first video flagged as a product/collection video %>
      <% product_video = @product.ashley_payload&.dig("videos")&.find { |v| v["product_video"] } %>
      <% if product_video %>
        <% video_id = product_video["url"].to_s.match(%r{youtu\.be/([^?]+)|v=([^&]+)})&.captures&.compact&.first %>
        <% if video_id %>
          <div class="mt-4 pt-4 border-t border-gray-100">
            <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Product Video</h4>
            <div class="aspect-video w-full rounded-md overflow-hidden bg-gray-100">
              <iframe
                src="https://www.youtube.com/embed/<%= video_id %>"
                title="<%= product_video['title'] %>"
                class="w-full h-full"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
              </iframe>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- Description -->
    <% if @product.short_description.present? || @product.description.body.present? %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-3">Description</h3>
        <% if @product.short_description.present? %>
          <div class="text-sm text-gray-600 mb-4 pb-4 border-b border-gray-50 italic">
            <%= @product.short_description %>
          </div>
        <% end %>
        <% if @product.description.body.present? %>
          <div class="prose text-sm max-w-none"><%= @product.description %></div>
        <% end %>
      </div>
    <% end %>

    <!-- Stock Adjustment -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h3 class="font-semibold text-gray-900 mb-4">Adjust Stock</h3>
      <%= form_with url: update_stock_admin_product_path(@product), method: :patch do |f| %>
        <div class="flex gap-3 items-end">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Quantity Change</label>
            <input type="number" name="quantity_change" placeholder="+10 or -5" required
                   class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 w-36">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Reason</label>
            <select name="reason" required class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500">
              <% StockAdjustment::REASONS.each do |reason| %>
                <option value="<%= reason %>"><%= reason.humanize %></option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="bg-gray-800 text-white text-sm px-4 py-2 rounded-md hover:bg-gray-700 transition-colors">
            Update Stock
          </button>
        </div>
      <% end %>

      <!-- Stock History -->
      <% recent_adjustments = @product.stock_adjustments.recent.limit(5) %>
      <% if recent_adjustments.any? %>
        <h4 class="font-medium text-gray-700 mt-6 mb-3 text-sm">Recent Adjustments</h4>
        <table class="min-w-full text-sm">
          <% recent_adjustments.each do |adj| %>
            <tr class="border-b border-gray-50 last:border-0">
              <td class="py-2 pr-4">
                <span class="font-medium <%= adj.quantity_change > 0 ? 'text-green-600' : 'text-red-600' %>">
                  <%= adj.quantity_change > 0 ? '+' : '' %><%= adj.quantity_change %>
                </span>
              </td>
              <td class="py-2 pr-4 text-gray-600"><%= adj.reason.humanize %></td>
              <td class="py-2 text-gray-400 text-xs"><%= adj.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </table>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h3 class="font-semibold text-gray-900 mb-4">Product Details</h3>
      <dl class="space-y-3 text-sm">
        <div>
          <dt class="text-gray-500">SKU</dt>
          <dd class="font-mono font-medium"><%= @product.sku %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Category</dt>
          <dd><%= @product.category.name %></dd>
        </div>
        <%= render "admin/products/price_section", product: @product %>
        <div>
          <dt class="text-gray-500">Current Stock</dt>
          <dd id="stock-display-<%= @product.id %>"><%= render "admin/products/stock_display", product: @product %></dd>
        </div>
        <% if @product.brand.present? %>
          <div>
            <dt class="text-gray-500">Brand</dt>
            <dd class="font-medium"><%= @product.brand %></dd>
          </div>
        <% end %>
        <% if @product.material.present? %>
          <div>
            <dt class="text-gray-500">Material</dt>
            <dd><%= @product.material %></dd>
          </div>
        <% end %>
        <% if @product.color.present? %>
          <div>
            <dt class="text-gray-500">Color</dt>
            <dd><%= @product.color %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-gray-500">Dimensions</dt>
          <dd>
            <% if (dims = @product.formatted_dimensions) %>
              <%= dims %>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-500">Weight</dt>
          <dd>
            <% if @product.weight.present? %>
              <%= @product.weight %> lbs
              <% if @product.large_item? %>
                <span class="ml-1 text-xs text-amber-600 font-medium">(Large item)</span>
              <% end %>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </dd>
        </div>
        <% desc_text = @product.description&.body&.to_plain_text&.strip.presence %>
        <div>
          <dt class="text-gray-500">Description</dt>
          <dd>
            <% if desc_text %>
              <p class="text-gray-700 text-xs leading-relaxed"><%= truncate(desc_text, length: 200) %></p>
            <% else %>
              <span class="text-gray-300">—</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-500">Featured</dt>
          <dd>
            <%= button_to @product.featured? ? "Remove from featured" : "Add to featured",
                toggle_featured_admin_product_path(@product), method: :patch,
                class: "text-sm text-amber-700 hover:underline bg-transparent border-0 cursor-pointer p-0 font-medium" %>
          </dd>
        </div>
        <% if @product.vendor_image_urls.present? %>
          <div class="pt-3 border-t border-gray-100">
            <dt class="text-gray-500 mb-2">Vendor Image URLs (<%= @product.vendor_image_urls.size %>)</dt>
            <dd class="space-y-2">
              <% @product.vendor_image_urls.each_with_index do |url, i| %>
                <div class="text-xs">
                  <span class="text-gray-400 font-medium">[<%= i + 1 %>]</span>
                  <%= link_to url.truncate(55), url, target: "_blank", rel: "noopener",
                      class: "font-mono text-amber-700 hover:underline break-all", title: url %>
                </div>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>

    <% if (payload = @product.ashley_payload.presence) %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Ashley Details</h3>
        <dl class="space-y-3 text-sm">
          <% [
            ["Style",    payload["style"]],
            ["Showroom", payload["showroom"]],
            ["Division", payload["division"]],
            ["Status",   payload["status"]],
            ["Ship By",  payload["ship_by"]],
          ].each do |label, value| %>
            <% next if value.blank? %>
            <div>
              <dt class="text-gray-500"><%= label %></dt>
              <dd class="font-medium"><%= value %></dd>
            </div>
          <% end %>

          <% if (extra = payload["extra_dimensions"]).present? %>
            <div class="pt-3 border-t border-gray-100">
              <dt class="text-gray-500 mb-2">Extra Dimensions</dt>
              <dd class="space-y-1">
                <% extra.each do |label, value| %>
                  <div class="flex gap-2 text-xs">
                    <span class="text-gray-400 font-medium w-40 shrink-0"><%= label %></span>
                    <span class="text-gray-700"><%= value %></span>
                  </div>
                <% end %>
              </dd>
            </div>
          <% end %>


          <% if (documents = payload["documents"]).present? %>
            <div class="pt-3 border-t border-gray-100">
              <dt class="text-gray-500 mb-2">Documents</dt>
              <dd class="space-y-1.5">
                <% documents.each do |doc| %>
                  <%= link_to doc["url"], target: "_blank", rel: "noopener",
                        class: "flex items-center gap-1.5 text-xs text-amber-700 hover:underline" do %>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                    <%= doc["type"] %> — <%= doc["filename"] %>
                  <% end %>
                <% end %>
              </dd>
            </div>
          <% end %>

          <% if @product.page_url.present? %>
            <div class="pt-3 border-t border-gray-100">
              <dt class="text-gray-500 mb-1">Dealer Page</dt>
              <dd><%= link_to "View on Ashley Direct ↗", @product.page_url,
                    target: "_blank", rel: "noopener",
                    class: "text-xs text-amber-700 hover:underline break-all" %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>
  </div>
</div>

<%# QR Code Label Section %>
<% if @product.qr_token.present? %>
  <div class="mt-6 bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-semibold text-gray-900">Product QR Code Label</h2>
      <%= link_to "Open Label Page ↗", qr_product_path(@product.qr_token),
          target: "_blank",
          class: "text-sm text-amber-700 hover:underline" %>
    </div>
    <div class="flex gap-8 items-start">
      <div class="border border-gray-200 rounded-lg p-3 bg-white shrink-0">
        <%== RQRCode::QRCode.new(qr_product_url(@product.qr_token)).as_svg(
          viewbox: true,
          use_path: true,
          svg_attributes: {
            width:  "140",
            height: "140",
            class:  "block"
          }
        ) %>
      </div>
      <div class="space-y-2 text-sm">
        <p class="text-gray-500">Scan this QR code to view the product label. Only signed-in admin users will see full product details.</p>
        <div class="font-mono text-xs text-gray-400 break-all"><%= qr_product_url(@product.qr_token) %></div>
        <button onclick="window.open('<%= qr_product_url(@product.qr_token) %>', '_blank').print()"
                class="inline-block bg-gray-800 text-white text-xs px-3 py-1.5 rounded-md hover:bg-gray-900 mt-2">
          Print Label
        </button>
      </div>
    </div>
  </div>
<% end %>
