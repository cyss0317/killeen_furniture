<%= form_with model: [:admin, product], multipart: true, data: { product_form: true }, class: "space-y-6" do |f| %>
  <%= render "shared/form_errors", object: product %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
    <!-- Main Product Info -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Basic Info -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Product Information</h3>
        <div class="space-y-4">
          <div>
            <%= f.label :name, "Product Name *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :name, required: true, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :brand, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :brand, placeholder: "Ashley Furniture", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            </div>
            <div>
              <%= f.label :sku, "SKU / Model # *", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :sku, required: true, placeholder: "AF12345",
                  id: "product_sku",
                  class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 uppercase",
                  oninput: "const l=document.getElementById('ashley-search-link'),v=this.value.trim();if(v){l.href='https://www.ashleyfurniture.com/search-results?q='+encodeURIComponent(v);l.classList.remove('invisible')}else{l.classList.add('invisible')}" %>
            </div>
          </div>
          <div>
            <%= f.label :page_url, "Vendor Page URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.url_field :page_url, placeholder: "https://www.ashleyfurniture.com/p/...",
                class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            <p class="text-xs text-gray-400 mt-1">Auto-filled from screenshot. Links back to the vendor product page.</p>
          </div>
          <div>
            <%= f.label :category_id, "Category *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.collection_select :category_id, @categories, :id, :name, { prompt: "Select category..." },
                { required: true, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" } %>
          </div>
          <div>
            <%= f.label :short_description, "Short Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :short_description, rows: 2, placeholder: "Brief summary shown on product cards...",
                class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
          <div>
            <%= f.label :description, "Full Description", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.rich_text_area :description, class: "block w-full" %>
          </div>
        </div>
      </div>

      <!-- Attributes -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Physical Attributes</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :color, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :color, placeholder: "Charcoal, Oak, etc.", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
          <div>
            <%= f.label :material, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :material, placeholder: "Solid wood, Fabric, etc.", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
          <div>
            <%= f.label :weight, "Weight (lbs)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :weight, step: 0.1, min: 0, placeholder: "85", class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            <p class="text-xs text-gray-400 mt-1">Items ≥ 50 lbs incur a large item delivery surcharge</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Dimensions (inches)</label>
            <div class="grid grid-cols-3 gap-1">
              <%= f.number_field "dimensions[width]", value: product.dimensions&.dig("width"), step: 0.1, placeholder: "W", class: "border border-gray-300 rounded-md px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
              <%= f.number_field "dimensions[height]", value: product.dimensions&.dig("height"), step: 0.1, placeholder: "H", class: "border border-gray-300 rounded-md px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
              <%= f.number_field "dimensions[depth]", value: product.dimensions&.dig("depth"), step: 0.1, placeholder: "D", class: "border border-gray-300 rounded-md px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Images -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-900">Product Images</h3>
          <a id="ashley-search-link"
             href="<%= product.sku.present? ? "https://www.ashleyfurniture.com/search-results?q=#{product.sku}" : "#" %>"
             target="_blank" rel="noopener"
             class="text-xs text-amber-700 hover:underline <%= product.sku.present? ? "" : "invisible" %>">
            Search Ashley ↗
          </a>
        </div>

        <%# Vendor image URLs — draggable, reorderable, removable %>
        <% if product.vendor_image_urls.present? %>
          <div class="mb-4" data-controller="image-sort">
            <div class="flex items-center justify-between mb-2">
              <p class="text-xs font-medium text-gray-600">
                Vendor Images
                <span class="font-normal text-gray-400">— drag to reorder · uncheck to remove</span>
              </p>
              <span class="text-xs text-gray-400">First image = main display image</span>
            </div>

            <%# Sentinel so the array key is always present even when all are unchecked %>
            <input type="hidden" name="product[vendor_image_urls][]" value="">

            <div class="grid grid-cols-4 sm:grid-cols-6 gap-2" data-image-sort-grid>
              <% product.vendor_image_urls.each_with_index do |url, i| %>
                <div class="relative group rounded-md overflow-hidden bg-gray-100 ring-2 ring-amber-500 transition-all cursor-grab active:cursor-grabbing select-none"
                     draggable="true"
                     data-image-sort-target="item">

                  <%# Hidden input carries the URL in DOM order — reordering DOM reorders submission %>
                  <input type="hidden" name="product[vendor_image_urls][]" value="<%= url %>">

                  <div class="aspect-square">
                    <%= image_tag url, class: "w-full h-full object-cover pointer-events-none", loading: "lazy" %>
                  </div>

                  <%# Primary badge — only shown on first item, refreshed by JS %>
                  <span data-primary-badge
                        class="absolute bottom-1 left-1 text-[10px] font-bold bg-amber-500 text-white px-1 rounded leading-4 pointer-events-none <%= i == 0 ? '' : 'hidden' %>">
                    Main
                  </span>

                  <%# Drag handle hint %>
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors pointer-events-none rounded-md"></div>

                  <%# Remove checkbox overlay %>
                  <label class="absolute top-1 right-1 cursor-pointer" title="Uncheck to remove">
                    <input type="checkbox" class="sr-only peer" checked
                           data-action="change->image-sort#toggle">
                    <div class="w-5 h-5 bg-white/80 backdrop-blur-sm rounded-full flex items-center justify-center ring-1 ring-gray-300 peer-checked:bg-amber-500 peer-checked:ring-amber-500 transition-all">
                      <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      <svg class="w-3 h-3 text-gray-400 peer-checked:hidden" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                      </svg>
                    </div>
                  </label>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Uploaded ActiveStorage images %>
        <% if product.images.attached? %>
          <div class="grid grid-cols-4 gap-2 mb-4">
            <% product.images.each do |image| %>
              <div class="aspect-square bg-gray-100 rounded-md overflow-hidden">
                <%= image_tag image.variant(resize_to_fill: [120, 120]), class: "w-full h-full object-cover" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Manual URL entry %>
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Add Image URLs</label>
          <textarea name="product[new_vendor_image_urls]" rows="4"
                    placeholder='One per line, comma-separated, or JSON array:&#10;["https://example.com/a.jpg","https://example.com/b.jpg"]'
                    class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-amber-500 resize-y"></textarea>
          <p class="text-xs text-gray-400 mt-1">Accepts one URL per line, comma-separated URLs, or a JSON array. Added to existing vendor images.</p>
        </div>

        <%= f.file_field :images, multiple: true, accept: "image/*",
            class: "block w-full text-sm text-gray-500 mt-4 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-amber-50 file:text-amber-700 hover:file:bg-amber-100" %>
        <p class="text-xs text-gray-400 mt-2">Upload multiple images. First image will be used as the primary image.</p>
      </div>
    </div>

    <!-- Pricing & Inventory Sidebar -->
    <div class="space-y-6 sticky top-6">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Pricing</h3>
        <div class="space-y-4">
          <div>
            <%= f.label :base_cost, "Base Cost (your cost) *", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="relative">
              <span class="absolute left-3 top-2 text-gray-500 text-sm">$</span>
              <%= f.number_field :base_cost, step: 0.01, min: 0, required: true,
                  class: "w-full border border-gray-300 rounded-md pl-7 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            </div>
          </div>
          <div>
            <%= f.label :markup_percentage, "Markup %", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <div class="relative">
              <%= f.number_field :markup_percentage, step: 0.1, min: 0,
                  placeholder: GlobalSetting.global_markup.to_s,
                  class: "w-full border border-gray-300 rounded-md px-3 pr-8 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
              <span class="absolute right-3 top-2 text-gray-500 text-sm">%</span>
            </div>
            <p class="text-xs text-gray-400 mt-1">Global default: <%= GlobalSetting.global_markup %>%. Leave 0 to use global.</p>
          </div>
          <div class="bg-amber-50 rounded-md p-3">
            <p class="text-xs text-gray-600 font-medium">Estimated Selling Price</p>
            <p class="text-lg font-bold text-amber-800" id="price-preview">
              <%= number_to_currency(product.selling_price || 0) %>
            </p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Inventory</h3>
        <div class="space-y-4">
          <div>
            <%= f.label :stock_quantity, "Stock Quantity", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.number_field :stock_quantity, min: 0, class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="font-semibold text-gray-900 mb-4">Publishing</h3>
        <div class="space-y-3">
          <div>
            <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.select :status, options_for_select([["Draft", "draft"], ["Published", "published"], ["Archived", "archived"]], product.status),
                {},
                class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
          <div>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.check_box :featured, class: "rounded border-gray-300 text-amber-700 focus:ring-amber-500" %>
              <span class="text-sm text-gray-700">Feature on homepage</span>
            </label>
          </div>
        </div>
      </div>

      <div class="flex gap-3">
        <%= f.submit product.new_record? ? "Create Product" : "Save Changes",
            class: "flex-1 bg-amber-800 text-white text-sm font-semibold py-2.5 px-4 rounded-md hover:bg-amber-900 transition-colors cursor-pointer text-center" %>
        <%= link_to "Cancel", admin_products_path, class: "flex-1 border border-gray-300 text-gray-700 text-sm font-medium py-2.5 px-4 rounded-md hover:bg-gray-50 transition-colors text-center" %>
      </div>
    </div>
  </div>
<% end %>
