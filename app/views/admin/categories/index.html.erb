<% content_for :title, "Categories" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Categories</h1>
  <%= link_to "Add Category", new_admin_category_path, class: "px-4 py-2 bg-amber-800 text-white text-sm font-medium rounded-md hover:bg-amber-900 transition-colors" %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden"
     data-controller="category-drop">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Products</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @root_categories.each do |parent| %>
        <%# Parent row %>
        <tr class="bg-gray-50/70 hover:bg-gray-100/60">
          <td class="px-6 py-3 text-sm font-semibold text-gray-900 transition-colors"
              data-category-id="<%= parent.id %>"
              data-action="dragover->category-drop#dragOver dragleave->category-drop#dragLeave drop->category-drop#drop">
            <%= parent.name %>
            <% if parent.subcategories.any? %>
              <span class="ml-1.5 text-xs font-normal text-gray-400">
                (<%= parent.subcategories.size %> subcategories)
              </span>
            <% end %>
            <div class="flex flex-wrap gap-2 mt-2" data-pills-container>
              <% parent.products.sort_by(&:name).each do |product| %>
                <%= link_to product.name, admin_product_path(product),
                    draggable: true,
                    data: {
                      product_id:  product.id,
                      category_id: parent.id,
                      action:      "dragstart->category-drop#dragStart dragend->category-drop#dragEnd"
                    },
                    class: "inline-block text-xs font-normal text-amber-800 bg-amber-50 border border-amber-200 rounded px-1.5 py-0.5 hover:bg-amber-100 transition-colors cursor-grab active:cursor-grabbing" %>
              <% end %>
            </div>
          </td>
          <td class="px-6 py-3 text-center text-sm text-gray-600"
              data-count-for="<%= parent.id %>"><%= parent.products.size %></td>
          <td class="px-6 py-3 text-right">
            <div class="flex justify-end items-center gap-3">
              <%= link_to "Edit", edit_admin_category_path(parent), class: "text-sm text-amber-700 hover:underline font-medium" %>
              <% blockers = []
                 blockers << pluralize(parent.products.size,     "product")     if parent.products.any?
                 blockers << pluralize(parent.subcategories.size, "subcategory") if parent.subcategories.any? %>
              <% if blockers.empty? %>
                <%= button_to "Delete", admin_category_path(parent), method: :delete,
                    form: { class: "contents", data: { turbo_confirm: "Delete '#{parent.name}'?" } },
                    class: "text-sm text-red-600 hover:underline font-medium bg-transparent border-0 cursor-pointer p-0" %>
              <% else %>
                <button type="button" disabled
                        title="Move <%= blockers.to_sentence %> out first"
                        class="text-sm text-gray-300 font-medium bg-transparent border-0 cursor-not-allowed p-0">
                  Delete
                </button>
              <% end %>
            </div>
          </td>
        </tr>
        <%# Child rows %>
        <% parent.subcategories.sort_by { |s| [s.position.to_i, s.name] }.each do |child| %>
          <tr class="hover:bg-gray-50">
            <td class="py-3 text-sm text-gray-800 transition-colors"
                data-category-id="<%= child.id %>"
                data-action="dragover->category-drop#dragOver dragleave->category-drop#dragLeave drop->category-drop#drop">
              <span class="inline-block w-10 text-center text-gray-300 select-none">└</span>
              <%= child.name %>
              <div class="flex flex-wrap gap-1 mt-1.5 ml-10" data-pills-container>
                <% child.products.sort_by(&:name).each do |product| %>
                  <%= link_to product.name, admin_product_path(product),
                      draggable: true,
                      data: {
                        product_id:  product.id,
                        category_id: child.id,
                        action:      "dragstart->category-drop#dragStart dragend->category-drop#dragEnd"
                      },
                      class: "inline-block text-xs font-normal text-amber-800 bg-amber-50 border border-amber-200 rounded px-1.5 py-0.5 hover:bg-amber-100 transition-colors cursor-grab active:cursor-grabbing" %>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-3 text-center text-sm text-gray-600"
                data-count-for="<%= child.id %>"><%= child.products.size %></td>
            <td class="px-6 py-3 text-right">
              <div class="flex justify-end items-center gap-3">
                <%= link_to "Edit", edit_admin_category_path(child), class: "text-sm text-amber-700 hover:underline font-medium" %>
                <% if child.products.empty? %>
                  <%= button_to "Delete", admin_category_path(child), method: :delete,
                      form: { class: "contents", data: { turbo_confirm: "Delete '#{child.name}'?" } },
                      class: "text-sm text-red-600 hover:underline font-medium bg-transparent border-0 cursor-pointer p-0" %>
                <% else %>
                  <button type="button" disabled
                          title="Move <%= pluralize(child.products.size, 'product') %> out first"
                          class="text-sm text-gray-300 font-medium bg-transparent border-0 cursor-not-allowed p-0">
                    Delete
                  </button>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
