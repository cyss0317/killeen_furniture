<% content_for :title, "Email Logs" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-bold text-gray-900">Email Logs</h1>
  <span class="text-sm text-gray-500"><%= @pagy.count %> total</span>
</div>

<!-- Filters -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6">
  <%= form_with url: admin_email_logs_path, method: :get, data: { turbo: false } do |f| %>
    <div class="flex flex-wrap gap-3 items-end">
      <div class="flex-1 min-w-48">
        <label class="block text-xs font-medium text-gray-500 mb-1">Search recipient or subject</label>
        <%= f.search_field :q, value: params[:q], placeholder: "Email address or subject…",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Email type</label>
        <%= f.select :action_name,
            [["All types", ""]] + @action_names,
            { selected: params[:action_name] },
            class: "border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>
      <%= f.submit "Filter", class: "px-4 py-2 bg-amber-800 text-white text-sm font-medium rounded-md hover:bg-amber-900 transition-colors cursor-pointer" %>
      <% if params[:q].present? || params[:action_name].present? %>
        <%= link_to "Clear", admin_email_logs_path,
            class: "px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Table -->
<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sent At</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Recipient</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Order</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @logs.each do |log| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-gray-500 whitespace-nowrap">
              <%= log.sent_at.strftime("%b %d, %Y %l:%M %p") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% badge_color = case log.action_name
                when "confirmation"             then "bg-green-100 text-green-700"
                when "admin_notification"       then "bg-gray-100 text-gray-600"
                when "delivery_assigned"        then "bg-blue-100 text-blue-700"
                when "out_for_delivery"         then "bg-amber-100 text-amber-700"
                when "order_delivered",
                     "order_delivered_customer" then "bg-purple-100 text-purple-700"
                else                                 "bg-gray-100 text-gray-600"
                end %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= badge_color %>">
                <%= log.label %>
              </span>
            </td>
            <td class="px-6 py-4 text-gray-700 font-mono text-xs"><%= log.to %></td>
            <td class="px-6 py-4 text-gray-600 max-w-xs truncate"><%= log.subject %></td>
            <td class="px-6 py-4">
              <% if log.order %>
                <%= link_to log.order.order_number, admin_order_path(log.order),
                    class: "font-mono text-amber-700 hover:underline text-xs" %>
              <% else %>
                <span class="text-gray-300">—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @logs.empty? %>
    <div class="py-12 text-center text-gray-400 text-sm">No emails logged yet.</div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-6 flex justify-center"><%== @pagy.series_nav %></div>
<% end %>
