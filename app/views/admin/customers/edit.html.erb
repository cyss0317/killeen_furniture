<% content_for :title, "Edit Customer – #{@customer.full_name}" %>

<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to admin_customers_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900">Edit Customer</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= render "shared/form_errors", object: @customer %>

    <%= form_with model: @customer, url: admin_customer_path(@customer), method: :patch, class: "space-y-5" do |f| %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, "First Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, required: true,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
        <div>
          <%= f.label :last_name, "Last Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, required: true,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
      </div>

      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, required: true,
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>

      <div>
        <%= f.label :phone, "Phone", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.telephone_field :phone, placeholder: "(555) 555-5555",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>

      <div class="pt-2 flex items-center gap-3">
        <%= f.submit "Save Changes",
            class: "px-5 py-2 bg-amber-800 text-white text-sm font-medium rounded-md hover:bg-amber-900 transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_customers_path,
            class: "px-5 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- Account info (read-only) -->
  <div class="mt-4 bg-gray-50 rounded-lg border border-gray-200 p-4 text-xs text-gray-500 space-y-1">
    <p><span class="font-medium text-gray-600">Customer since:</span> <%= @customer.created_at.strftime("%B %d, %Y") %></p>
    <p><span class="font-medium text-gray-600">Sign-in method:</span> <%= @customer.provider&.humanize || "Email / Password" %></p>
  </div>
</div>
