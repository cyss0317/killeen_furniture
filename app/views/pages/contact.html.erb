<% content_for :title, "Contact Warehouse Furniture – Killeen, TX Furniture Store" %>
<% content_for :description, "Contact Warehouse Furniture in Killeen, TX. Visit us at 1104 E Veterans Memorial Blvd, call (254) 628-9088, or shop online. Open Mon–Sat 11 AM–6 PM." %>
<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FurnitureStore",
  "name": "Warehouse Furniture",
  "url": "<%= contact_url %>",
  "telephone": "+12546289088",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1104 E Veterans Memorial Blvd",
    "addressLocality": "Killeen",
    "addressRegion": "TX",
    "postalCode": "76541",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 31.1171,
    "longitude": -97.7278
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "11:00",
      "closes": "18:00"
    }
  ],
  "hasMap": "https://www.google.com/maps/search/?api=1&query=1104+E+Veterans+Memorial+Blvd+Killeen+TX+76541"
}
</script>
<% end %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

  <div class="text-center mb-12">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-warm-500 mb-3">Killeen, TX</p>
    <h1 class="text-4xl font-bold text-warm-950 mb-4">Contact Us</h1>
    <p class="text-warm-600 text-base max-w-xl mx-auto">
      Stop by our showroom, give us a call, or browse online. We're here to help you find the right furniture for your home.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">

    <!-- Address & Hours -->
    <div class="bg-white rounded-2xl border border-warm-300 p-8 space-y-7">

      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-warm-100 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-warm-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-warm-900 mb-1">Store Address</p>
          <address class="not-italic text-sm text-warm-600 leading-relaxed">
            1104 E Veterans Memorial Blvd<br>
            Killeen, TX 76541<br>
            United States
          </address>
          <%= link_to "Get Directions →",
              "https://www.google.com/maps/search/?api=1&query=1104+E+Veterans+Memorial+Blvd+Killeen+TX+76541",
              target: "_blank", rel: "noopener noreferrer",
              class: "inline-block mt-2 text-xs font-semibold text-warm-700 hover:text-warm-950 underline underline-offset-4 transition-colors" %>
        </div>
      </div>

      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-warm-100 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-warm-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-warm-900 mb-1">Phone</p>
          <%= link_to "(254) 628-9088", "tel:+12546289088",
              class: "text-sm text-warm-600 hover:text-warm-950 transition-colors" %>
        </div>
      </div>

      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-warm-100 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-warm-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-warm-900 mb-2">Store Hours</p>
          <dl class="space-y-1 text-sm text-warm-600">
            <div class="flex justify-between gap-8">
              <dt>Monday – Saturday</dt>
              <dd class="font-medium text-warm-800">11:00 AM – 6:00 PM</dd>
            </div>
            <div class="flex justify-between gap-8">
              <dt>Sunday</dt>
              <dd class="text-warm-400">Closed</dd>
            </div>
          </dl>
        </div>
      </div>

    </div>

    <!-- Google Maps embed -->
    <div class="rounded-2xl overflow-hidden border border-warm-300 bg-warm-100 min-h-72">
      <iframe
        title="Warehouse Furniture location — 1104 E Veterans Memorial Blvd, Killeen TX"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3432.563!2d-97.7278!3d31.1171!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1104+E+Veterans+Memorial+Blvd+Killeen+TX+76541!5e0!3m2!1sen!2sus!4v1"
        width="100%" height="100%"
        style="border:0; min-height: 288px;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>

  </div>

  <!-- Local area note -->
  <div class="bg-warm-50 border border-warm-300 rounded-2xl p-8 text-center">
    <h2 class="text-lg font-bold text-warm-950 mb-2">Serving Killeen &amp; Surrounding Communities</h2>
    <p class="text-sm text-warm-600 max-w-2xl mx-auto">
