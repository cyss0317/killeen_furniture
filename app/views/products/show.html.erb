<% content_for :title, "#{@product.name} — #{APP_NAME}" %>
<% content_for :description, @product.short_description.presence || "Shop #{@product.name} at Warehouse Furniture. Quality Ashley Furniture with local delivery in the Killeen, TX area." %>
<% if @product.vendor_image_urls.present? %>
  <% content_for :og_image, @product.vendor_image_urls.first %>
<% end %>
<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "<%= j @product.name %>",
  "description": "<%= j(@product.short_description.presence || @product.name) %>",
  "image": <%= @product.vendor_image_urls.presence&.to_json || "[]" %>,
  "brand": {
    "@type": "Brand",
    "name": "<%= j(@product.brand.presence || "Ashley Furniture") %>"
  },
  "offers": {
    "@type": "Offer",
    "url": "<%= product_url(@product) %>",
    "priceCurrency": "USD",
    "price": "<%= @product.selling_price %>",
    "availability": "<%= @product.stock_quantity.to_i > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock" %>"
  }
}
</script>
<% end %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 mb-8 text-sm" aria-label="Breadcrumb">
    <%= link_to "Home", root_path, class: "text-warm-600 hover:text-warm-900 transition-colors" %>
    <span class="text-warm-300">/</span>
    <%= link_to "Shop", products_path, class: "text-warm-600 hover:text-warm-900 transition-colors" %>
    <span class="text-warm-300">/</span>
    <span class="text-warm-800 font-medium truncate max-w-xs"><%= @product.name %></span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12" data-controller="reveal">

    <!-- Images -->
    <div>
      <% if @product.vendor_image_urls.present? %>
        <% images = @product.vendor_image_urls %>
        <% product_video = @product.ashley_payload&.dig("videos")&.find { |v| v["product_video"] } %>
        <% video_id = product_video&.dig("url").to_s.match(%r{youtu\.be/([^?]+)|v=([^&]+)})&.captures&.compact&.first %>
        <% total_thumbs = images.size + (video_id ? 1 : 0) %>
        <div data-controller="image-gallery">
          <%# Main display — image or video iframe %>
          <div class="relative aspect-square bg-warm-200 rounded-2xl overflow-hidden mb-3 group">
            <%= image_tag images.first,
                class: "w-full h-full object-cover cursor-zoom-in",
                alt: @product.name,
                loading: "eager",
                data: { "image-gallery-target": "main", action: "click->image-gallery#openLightbox" } %>

            <% if video_id %>
              <iframe
                src=""
                title="<%= @product.name %> video"
                class="hidden w-full h-full"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                data-image-gallery-target="videoFrame"></iframe>
            <% end %>

            <%# Prev arrow %>
            <button type="button"
                    data-image-gallery-target="prev"
                    data-action="click->image-gallery#prev"
                    class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 bg-white/80 hover:bg-white rounded-full shadow flex items-center justify-center transition-opacity opacity-0 group-hover:opacity-100 cursor-pointer"
                    aria-label="Previous image">
              <svg class="w-4 h-4 text-warm-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>

            <%# Next arrow %>
            <button type="button"
                    data-image-gallery-target="next"
                    data-action="click->image-gallery#next"
                    class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 bg-white/80 hover:bg-white rounded-full shadow flex items-center justify-center transition-opacity opacity-0 group-hover:opacity-100 cursor-pointer"
                    aria-label="Next image">
              <svg class="w-4 h-4 text-warm-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>

          <%# Thumbnails + video thumbnail %>
          <% if total_thumbs > 1 %>
            <div class="grid grid-cols-4 gap-2">
              <% images.each_with_index do |url, idx| %>
                <div class="aspect-square bg-warm-200 rounded-xl overflow-hidden cursor-pointer border-2 hover:border-warm-500 transition-colors <%= idx == 0 ? 'border-warm-600' : 'border-transparent' %>"
                     data-image-gallery-target="thumb"
                     data-gallery-src="<%= url %>"
                     data-gallery-index="<%= idx %>"
                     data-action="click->image-gallery#select">
                  <%= image_tag url, class: "w-full h-full object-cover", alt: @product.name, loading: "lazy" %>
                </div>
              <% end %>

              <% if video_id %>
                <div class="relative aspect-square bg-warm-900 rounded-xl overflow-hidden cursor-pointer border-2 border-transparent hover:border-warm-500 transition-colors"
                     data-image-gallery-target="thumb"
                     data-gallery-type="video"
                     data-gallery-video-id="<%= video_id %>"
                     data-gallery-index="<%= images.size %>"
                     data-action="click->image-gallery#select">
                  <img src="https://img.youtube.com/vi/<%= video_id %>/hqdefault.jpg"
                       alt="Product video"
                       class="w-full h-full object-cover opacity-70">
                  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                    <div class="w-8 h-8 bg-white/90 rounded-full flex items-center justify-center">
                      <svg class="w-4 h-4 text-warm-900 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <%# Lightbox modal %>
          <div data-image-gallery-target="lightbox"
               class="hidden fixed z-50 backdrop-blur-xl"
               style="background:rgba(0,0,0,0.4);top:0;left:0;width:100vw;height:100vh"
               data-action="click->image-gallery#closeLightbox">

            <%# Big image — fills left portion of modal, fixed to viewport edges %>
            <div class="fixed top-16 bottom-16 left-16 right-40 z-10 rounded-2xl overflow-hidden bg-black/20 flex items-center justify-center shadow-2xl"
                 data-action="click->image-gallery#closeLightbox">
              <img src="" alt="<%= @product.name %>"
                   class="w-full h-full object-contain"
                   data-image-gallery-target="lightboxImg"
                   data-action="click.prevent">
            </div>

            <%# Thumbnail strip — fixed to right edge, full height %>
            <div class="fixed right-6 top-8 bottom-8 z-20 flex flex-col gap-2.5 overflow-y-auto w-24 py-1 px-1"
                 data-action="click.prevent">
              <% images.each_with_index do |url, idx| %>
                <button type="button"
                        class="shrink-0 w-full h-20 rounded-xl overflow-hidden opacity-50 transition-all duration-150 cursor-pointer hover:opacity-80 ring-2 ring-transparent"
                        data-image-gallery-target="lightboxThumb"
                        data-lightbox-index="<%= idx %>"
                        data-action="click->image-gallery#selectLightbox">
                  <img src="<%= url %>" alt="Image <%= idx + 1 %>"
                       class="w-full h-full object-cover">
                </button>
              <% end %>
            </div>

            <%# Close button %>
            <button type="button"
                    class="fixed top-5 left-5 z-20 w-10 h-10 bg-white/15 hover:bg-white/25 text-white rounded-full flex items-center justify-center backdrop-blur-sm transition-colors cursor-pointer"
                    data-action="click->image-gallery#closeLightbox"
                    aria-label="Close">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>

            <%# Arrow nav %>
            <button type="button"
                    class="fixed left-5 top-1/2 -translate-y-1/2 z-20 w-11 h-11 bg-white/15 hover:bg-white/25 text-white rounded-full flex items-center justify-center backdrop-blur-sm transition-colors cursor-pointer"
                    data-action="click->image-gallery#prev"
                    aria-label="Previous">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            <button type="button"
                    class="fixed right-5 top-1/2 -translate-y-1/2 z-20 w-11 h-11 bg-white/15 hover:bg-white/25 text-white rounded-full flex items-center justify-center backdrop-blur-sm transition-colors cursor-pointer"
                    data-action="click->image-gallery#next"
                    aria-label="Next">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>
        </div>

      <% elsif @product.images.attached? %>
        <% as_images = @product.images.to_a %>
        <div data-controller="image-gallery">
          <div class="relative aspect-square bg-warm-200 rounded-2xl overflow-hidden mb-3 group">
            <%= image_tag @product.primary_image.variant(resize_to_fill: [600, 600]),
                class: "w-full h-full object-cover",
                alt: @product.name,
                data: { "image-gallery-target": "main" } %>

            <button type="button"
                    data-image-gallery-target="prev"
                    data-action="click->image-gallery#prev"
                    class="absolute left-3 top-1/2 -translate-y-1/2 w-9 h-9 bg-white/80 hover:bg-white rounded-full shadow flex items-center justify-center transition-opacity opacity-0 group-hover:opacity-100 cursor-pointer"
                    aria-label="Previous image">
              <svg class="w-4 h-4 text-warm-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>

            <button type="button"
                    data-image-gallery-target="next"
                    data-action="click->image-gallery#next"
                    class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 bg-white/80 hover:bg-white rounded-full shadow flex items-center justify-center transition-opacity opacity-0 group-hover:opacity-100 cursor-pointer"
                    aria-label="Next image">
              <svg class="w-4 h-4 text-warm-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>

          <% if as_images.size > 1 %>
            <div class="grid grid-cols-4 gap-2">
              <% as_images.each_with_index do |image, idx| %>
                <div class="aspect-square bg-warm-200 rounded-xl overflow-hidden cursor-pointer border-2 hover:border-warm-500 transition-colors <%= idx == 0 ? 'border-warm-600' : 'border-transparent' %>"
                     data-image-gallery-target="thumb"
                     data-gallery-src="<%= url_for(image.variant(resize_to_fill: [600, 600])) %>"
                     data-gallery-index="<%= idx %>"
                     data-action="click->image-gallery#select">
                  <%= image_tag image.variant(resize_to_fill: [150, 150]), class: "w-full h-full object-cover", alt: @product.name %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

      <% else %>
        <div class="aspect-square bg-warm-200 rounded-2xl flex items-center justify-center">
          <svg class="w-24 h-24 text-warm-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      <% end %>
    </div>

    <!-- Product Info -->
    <div class="flex flex-col">
      <% if @product.brand.present? %>
        <%= link_to brand_path(@product.brand),
              class: "inline-block text-xs font-semibold tracking-[0.15em] uppercase text-warm-600 hover:text-warm-900 mb-3 transition-colors" do %>
          Brand: <%= @product.brand %>
        <% end %>
      <% end %>

      <h1 class="text-3xl font-bold text-warm-950 leading-tight mb-2"><%= @product.name %></h1>

      <div class="mb-5">
        <span class="text-3xl font-bold text-warm-900"><%= number_to_currency(@product.selling_price) %></span>
      </div>

      <% if @product.short_description.present? %>
        <p class="text-warm-600 leading-relaxed mb-6 text-sm"><%= @product.short_description %></p>
      <% end %>

      <!-- Stock Status -->
      <div class="mb-6">
        <% if @product.in_stock? %>
          <span class="inline-flex items-center gap-1.5 text-green-700 bg-green-50 border border-green-100 px-3 py-1 rounded-full text-sm font-medium">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
            In Stock (<%= @product.stock_quantity %> available)
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 text-red-600 bg-red-50 border border-red-100 px-3 py-1 rounded-full text-sm font-medium">
            <span class="w-2 h-2 bg-red-400 rounded-full"></span>
            Out of Stock
          </span>
        <% end %>
      </div>

      <!-- Add to Cart -->
      <% if @product.in_stock? %>
        <%= form_with url: add_item_cart_path, method: :post, data: { turbo: true } do |f| %>
          <%= f.hidden_field :product_id, value: @product.id %>
          <div class="flex gap-3 mb-4">
            <div class="flex items-center border border-warm-400 rounded-full bg-white overflow-hidden">
              <button type="button"
                      onclick="this.nextElementSibling.value = Math.max(1, parseInt(this.nextElementSibling.value) - 1)"
                      class="px-4 py-2.5 text-warm-600 hover:text-warm-900 font-bold text-lg leading-none">−</button>
              <%= f.number_field :quantity, value: 1, min: 1, max: @product.stock_quantity,
                  class: "w-12 text-center border-0 focus:ring-0 text-sm font-semibold text-warm-900 bg-transparent",
                  id: "qty-field" %>
              <button type="button"
                      onclick="this.previousElementSibling.value = Math.min(<%= @product.stock_quantity %>, parseInt(this.previousElementSibling.value) + 1)"
                      class="px-4 py-2.5 text-warm-600 hover:text-warm-900 font-bold text-lg leading-none">+</button>
            </div>
            <%= f.submit "Add to Cart",
                class: "flex-1 bg-warm-800 text-warm-50 font-semibold py-3 px-6 rounded-full hover:bg-warm-700 transition-colors cursor-pointer text-center" %>
          </div>
        <% end %>
      <% end %>

      <!-- Product Details -->
      <div class="border-t border-warm-200 pt-6 space-y-3 mt-2">
        <% payload = @product.ashley_payload.presence %>
        <% [
          ["Brand",      @product.brand],
          ["Style",      payload&.dig("style")],
          ["Material",   @product.material],
          ["Color",      @product.color],
          ["Dimensions", @product.try(:formatted_dimensions)],
          ["Weight",     @product.weight.present? ? "#{@product.weight} lbs" : nil],
        ].each do |label, value| %>
          <% if value.present? %>
            <div class="flex text-sm">
              <span class="w-28 text-warm-600 font-medium"><%= label %></span>
              <span class="text-warm-800"><%= value %></span>
            </div>
          <% end %>
        <% end %>
        <% if @product.category.present? %>
          <div class="flex text-sm">
            <span class="w-28 text-warm-600 font-medium">Category</span>
            <%= link_to @product.category.name, category_path(@product.category),
                class: "text-warm-700 hover:text-warm-950 underline underline-offset-2" %>
          </div>
        <% end %>

        <% if (extra = payload&.dig("extra_dimensions")).present? %>
          <details class="pt-1">
            <summary class="text-sm text-warm-500 cursor-pointer hover:text-warm-800 select-none font-medium">
              More dimensions
            </summary>
            <div class="mt-3 space-y-2 pl-1">
              <% extra.each do |label, value| %>
                <div class="flex text-sm">
                  <span class="w-28 text-warm-500"><%= label %></span>
                  <span class="text-warm-700"><%= value %></span>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>

      <!-- Description -->
      <% has_rich_description = @product.description&.body&.present? %>
      <% if has_rich_description || @product.short_description.present? %>
        <div class="border-t border-warm-200 pt-6 mt-6">
          <h2 class="text-sm font-semibold text-warm-900 mb-3">Description</h2>
          <% if has_rich_description %>
            <%= render_description(@product.description.to_plain_text) %>
          <% else %>
            <%= render_description(@product.short_description) %>
          <% end %>
        </div>
      <% end %>

      <!-- Documents — Assembly Instructions, admin only -->
      <% if current_user&.admin_or_above? && (documents = payload&.dig("documents")&.select { |d| d["type"] == "Assembly Instructions" }).present? %>
        <div class="border-t border-warm-200 pt-6 mt-6">
          <h2 class="text-sm font-semibold text-warm-900 mb-3">Documents</h2>
          <div class="space-y-2">
            <% documents.each do |doc| %>
              <%= link_to doc["url"], target: "_blank", rel: "noopener",
                    class: "flex items-center gap-2.5 text-sm text-warm-700 hover:text-warm-950 transition-colors group" do %>
                <div class="w-8 h-8 bg-warm-100 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-warm-200 transition-colors">
                  <svg class="w-4 h-4 text-warm-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                  </svg>
                </div>
                <span class="underline underline-offset-2"><%= doc["type"] %></span>
                <svg class="w-3.5 h-3.5 text-warm-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Related Products -->
  <% if @related.any? %>
    <section class="mt-16" data-controller="reveal">
      <div class="mb-6">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase text-warm-600 mb-1">More to Explore</p>
        <h2 class="text-xl font-bold text-warm-950">You Might Also Like</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        <% @related.each_with_index do |product, i| %>
          <%= render "products/product_card", product: product, reveal_delay: i * 80 %>
        <% end %>
      </div>
    </section>
  <% end %>

</div>
