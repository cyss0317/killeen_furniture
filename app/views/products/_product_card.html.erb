<article class="group bg-warm-50 rounded-2xl overflow-hidden border border-warm-300 card-hover"
         data-controller="reveal"
         data-reveal-delay="<%= local_assigns[:reveal_delay] || 0 %>">
  <%= link_to product_path(product) do %>
    <div class="aspect-square bg-warm-200 overflow-hidden rounded-t-2xl relative">
      <% if product.vendor_image_urls.present? %>
        <%= image_tag product.vendor_image_urls.first,
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500",
            alt: product.name %>
      <% elsif product.images.attached? && product.primary_image %>
        <%= image_tag product.primary_image.variant(resize_to_fill: [400, 400]),
            class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500",
            alt: product.name %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center text-warm-300">
          <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      <% end %>
      <!-- Stock badge -->
      <% unless product.in_stock? %>
        <div class="absolute top-3 left-3 bg-warm-950/70 text-warm-100 text-xs font-medium px-2.5 py-1 rounded-full">
          Out of Stock
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="p-4">
    <p class="text-xs text-warm-600 mb-1"><%= product.brand %></p>
    <%= link_to product.name, product_path(product),
        class: "font-semibold text-warm-900 hover:text-warm-600 transition-colors line-clamp-2 text-sm leading-snug" %>
    <div class="flex items-center justify-between mt-3">
      <span class="text-base font-bold text-warm-900"><%= number_to_currency(product.selling_price) %></span>
      <%= link_to "Shop Now", product_path(product),
          class: "text-xs font-semibold text-warm-700 hover:text-warm-950 transition-colors" %>
    </div>
  </div>
</article>
