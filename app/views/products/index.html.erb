<% content_for :title, "Shop All Furniture — #{APP_NAME} | Killeen, TX" %>
<% content_for :description, "Browse our full collection of Ashley Furniture including sofas, sectionals, beds, dining sets, and more. Local delivery available in the Killeen, TX area." %>
<% content_for :head do %><meta name="turbo-cache-control" content="no-store"><% end %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-8">

    <!-- Sidebar Filters -->
    <aside class="lg:w-60 flex-shrink-0">
      <div class="bg-warm-50 rounded-2xl border border-warm-400 p-6 sticky top-20" data-controller="reveal">
        <h2 class="font-bold text-warm-900 text-sm uppercase tracking-widest mb-5">Filters</h2>

        <%= form_with url: products_path, method: :get, data: { turbo: false } do |f| %>
          <!-- Search -->
          <div class="mb-5">
            <label class="block text-xs font-semibold text-warm-700 uppercase tracking-wide mb-2">Search</label>
            <%= f.search_field :q, value: params[:q], placeholder: "Name, SKU, brand...",
                class: "w-full text-sm border border-warm-400 rounded-xl bg-white px-3 py-2 text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent" %>
          </div>

          <!-- Category -->
          <div class="mb-5">
            <label class="block text-xs font-semibold text-warm-700 uppercase tracking-wide mb-2">Category</label>
            <%= f.select :category_id,
                options_for_select([["All Categories", ""]] + @categories.map { |c| [c.name, c.id] }, params[:category_id]),
                {},
                class: "w-full text-sm border border-warm-400 rounded-xl bg-white px-3 py-2 text-warm-900 focus:outline-none focus:ring-2 focus:ring-warm-400",
                onchange: "this.form.submit()" %>
          </div>

          <!-- Color / Finish -->
          <% if @colors.any? %>
            <div class="mb-5">
              <label class="block text-xs font-semibold text-warm-700 uppercase tracking-wide mb-2">Color / Finish</label>
              <%# Hidden input holds the selected value — swatches update it and submit %>
              <%= f.hidden_field :color, value: params[:color], id: "color-filter-value" %>
              <div class="flex flex-wrap gap-1.5">
                <%# "All" option %>
                <button type="button"
                        onclick="document.getElementById('color-filter-value').value = ''; this.closest('form').submit();"
                        class="flex items-center gap-1.5 px-2 py-1 rounded-lg text-xs border transition-colors cursor-pointer <%= params[:color].blank? ? 'border-warm-700 bg-warm-100 font-semibold text-warm-900' : 'border-warm-300 text-warm-600 hover:border-warm-500' %>">
                  All
                </button>
                <% @colors.each do |color| %>
                  <% selected = params[:color] == color %>
                  <button type="button"
                          onclick="document.getElementById('color-filter-value').value = '<%= j color %>'; this.closest('form').submit();"
                          title="<%= color %>"
                          class="flex items-center gap-1.5 px-2 py-1 rounded-lg text-xs border transition-colors cursor-pointer <%= selected ? 'border-warm-700 bg-warm-100 font-semibold text-warm-900' : 'border-warm-300 text-warm-600 hover:border-warm-500' %>">
                    <span class="w-3.5 h-3.5 rounded-full border border-black/10 flex-shrink-0"
                          style="background: <%= color_swatch_for_group(color) %>;"></span>
                    <%= color %>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>

          <!-- Price Range -->
          <div class="mb-5">
            <label class="block text-xs font-semibold text-warm-700 uppercase tracking-wide mb-2">Price Range</label>
            <div class="flex gap-2">
              <%= f.number_field :min_price, value: params[:min_price], placeholder: "Min", min: 0,
                  class: "w-full text-sm border border-warm-400 rounded-xl bg-white px-3 py-2 text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400" %>
              <%= f.number_field :max_price, value: params[:max_price], placeholder: "Max", min: 0,
                  class: "w-full text-sm border border-warm-400 rounded-xl bg-white px-3 py-2 text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400" %>
            </div>
          </div>

          <!-- In Stock Only -->
          <div class="mb-5">
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.check_box :in_stock, checked: params[:in_stock] == "1",
                  class: "rounded border-warm-400 accent-warm-700",
                  onchange: "this.form.submit()" %>
              <span class="text-sm text-warm-700">In Stock Only</span>
            </label>
          </div>

          <!-- Sort -->
          <div class="mb-5">
            <label class="block text-xs font-semibold text-warm-700 uppercase tracking-wide mb-2">Sort By</label>
            <%= f.select :sort,
                options_for_select([
                  ["Featured", ""],
                  ["Newest", "newest"],
                  ["Price: Low to High", "price_asc"],
                  ["Price: High to Low", "price_desc"]
                ], params[:sort]),
                {},
                class: "w-full text-sm border border-warm-400 rounded-xl bg-white px-3 py-2 text-warm-900 focus:outline-none focus:ring-2 focus:ring-warm-400",
                onchange: "this.form.submit()" %>
          </div>

          <%= f.submit "Apply Filters", class: "w-full bg-warm-800 text-warm-50 text-sm font-semibold py-2.5 px-4 rounded-full hover:bg-warm-700 transition-colors cursor-pointer" %>
          <%= link_to "Clear Filters", products_path, class: "block text-center text-sm text-warm-600 hover:text-warm-900 mt-3" %>
        <% end %>
      </div>
    </aside>

    <!-- Product Grid -->
    <div class="flex-1">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-warm-950">
            <% if params[:q].present? %>
              Results for "<%= params[:q] %>"
            <% else %>
              All Furniture
            <% end %>
          </h1>
        </div>
        <p class="text-sm text-warm-600"><%= @pagy.count %> products</p>
      </div>

      <% if @products.empty? %>
        <div class="text-center py-16 bg-warm-50 rounded-2xl border border-warm-400">
          <svg class="mx-auto w-12 h-12 text-warm-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
          </svg>
          <h3 class="text-warm-700 font-medium">No products found</h3>
          <p class="text-sm text-warm-600 mt-1">Try adjusting your filters</p>
          <%= link_to "Clear Filters", products_path, class: "mt-4 inline-block text-warm-700 hover:underline text-sm" %>
        </div>
      <% else %>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          <% @products.each_with_index do |product, i| %>
            <%= render "products/product_card", product: product, reveal_delay: (i % 3) * 80 %>
          <% end %>
        </div>

        <% if @pagy.pages > 1 %>
          <div class="mt-8 flex justify-center">
            <%== @pagy.series_nav %>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>
</div>
