<div class="container">
  <div class="header">
    <p class="header-wordmark">Warehouse Furniture</p>
    <p class="header-subtitle">Order Confirmation</p>
  </div>

  <div class="body">
    <p>Hi <%= @order.customer_name %>,</p>
    <p>Thank you for your order! We've received your payment and your order is confirmed.</p>

    <div class="info-box">
      <p><strong>Order Number:</strong> <%= @order.order_number %></p>
      <p><strong>Date:</strong> <%= @order.created_at.strftime("%B %d, %Y") %></p>
    </div>

    <div class="section">
      <p class="section-title">Order Summary</p>
      <table class="items">
        <% @order_items.each do |item| %>
          <tr>
            <td>
              <strong><%= item.product_name %></strong>
              <span class="item-meta">SKU: <%= item.product_sku %> &times; <%= item.quantity %></span>
            </td>
            <td style="text-align: right; font-weight: 600; white-space: nowrap;"><%= number_to_currency(item.line_total) %></td>
          </tr>
        <% end %>
        <tr>
          <td style="color: #8c6844; border-bottom: none; padding-top: 8px;">Subtotal</td>
          <td style="text-align: right; border-bottom: none; padding-top: 8px;"><%= number_to_currency(@order.subtotal) %></td>
        </tr>
        <tr>
          <td style="color: #8c6844; border-bottom: none;">Shipping</td>
          <td style="text-align: right; border-bottom: none;"><%= number_to_currency(@order.shipping_amount) %></td>
        </tr>
        <% if @order.tax_amount > 0 %>
          <tr>
            <td style="color: #8c6844; border-bottom: none;">Tax</td>
            <td style="text-align: right; border-bottom: none;"><%= number_to_currency(@order.tax_amount) %></td>
          </tr>
        <% end %>
        <tr class="total-row">
          <td>Total</td>
          <td style="text-align: right;"><%= number_to_currency(@order.grand_total) %></td>
        </tr>
      </table>
    </div>

    <div class="section">
      <p class="section-title">Delivery Address</p>
      <p style="font-size: 14px; line-height: 1.7; margin: 0;">
        <%= @order.shipping_address["full_name"] %><br>
        <%= @order.shipping_address["street_address"] %><br>
        <%= @order.shipping_address["city"] %>, <%= @order.shipping_address["state"] %> <%= @order.shipping_address["zip_code"] %>
      </p>
    </div>

    <p class="muted" style="margin-top: 24px;">We'll be in touch with delivery updates. If you have questions, please reply to this email.</p>
  </div>

  <div class="footer">
    <p>Warehouse Furniture · 1104 E Veterans Memorial Blvd, Killeen, TX 76541</p>
    <p>© <%= Time.current.year %> Warehouse Furniture. All rights reserved.</p>
  </div>
</div>
