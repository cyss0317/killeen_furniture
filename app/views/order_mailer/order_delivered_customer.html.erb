<div class="container">
  <div class="header">
    <p class="header-wordmark">Warehouse Furniture</p>
    <p class="header-subtitle">Your order has been delivered!</p>
  </div>

  <div class="body">
    <p>Hi <%= @order.customer_name %>,</p>
    <p>Your order has been successfully delivered. We hope you love your new furniture!</p>

    <div class="info-box">
      <p><strong>Order Number:</strong> <%= @order.order_number %></p>
      <p><strong>Delivered On:</strong> <%= @order.delivered_at&.strftime("%B %d, %Y") || "Today" %></p>
    </div>

    <div class="section">
      <p class="section-title">Items Delivered</p>
      <table class="items">
        <% @order_items.each do |item| %>
          <tr>
            <td>
              <strong><%= item.product_name %></strong>
              <span class="item-meta">SKU: <%= item.product_sku %></span>
            </td>
            <td style="text-align: right; white-space: nowrap;">&times; <%= item.quantity %></td>
          </tr>
        <% end %>
      </table>
    </div>

    <p class="muted" style="margin-top: 24px;">Thank you for choosing Warehouse Furniture. If you have any questions or concerns about your order, please don't hesitate to contact us.</p>
  </div>

  <div class="footer">
    <p>Warehouse Furniture · 1104 E Veterans Memorial Blvd, Killeen, TX 76541</p>
    <p>© <%= Time.current.year %> Warehouse Furniture. All rights reserved.</p>
  </div>
</div>
