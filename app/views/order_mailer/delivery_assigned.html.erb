<div class="container">
  <div class="header">
    <p class="header-wordmark">Warehouse Furniture</p>
    <p class="header-subtitle">Delivery Assignment</p>
  </div>

  <div class="body">
    <p>Hi <%= @delivery_user.first_name %>,</p>
    <p>You have been assigned a delivery. Please review the details below.</p>

    <div class="info-box">
      <p><strong>Order Number:</strong> <%= @order.order_number %></p>
      <p><strong>Customer:</strong> <%= @order.customer_name %></p>
      <p><strong>Phone:</strong> <%= @order.customer_phone.presence || "—" %></p>
    </div>

    <div class="section">
      <p class="section-title">Delivery Address</p>
      <% maps_url = google_maps_url(@order.shipping_address) %>
      <p style="font-size: 14px; line-height: 1.7; margin: 0;">
        <%= @order.shipping_address["full_name"] %><br>
        <a href="<%= maps_url %>">
          <%= @order.shipping_address["street_address"] %><br>
          <%= @order.shipping_address["city"] %>, <%= @order.shipping_address["state"] %> <%= @order.shipping_address["zip_code"] %>
        </a>
      </p>
    </div>

    <div class="section">
      <p class="section-title">Items to Deliver</p>
      <table class="items">
        <% @order_items.each do |item| %>
          <tr>
            <td>
              <% if item.product %>
                <a href="<%= product_url(item.product) %>" style="font-weight: 600;"><%= item.product_name %></a>
              <% else %>
                <strong><%= item.product_name %></strong>
              <% end %>
              <span class="item-meta">SKU: <%= item.product_sku %></span>
            </td>
            <td style="text-align: right; white-space: nowrap;">&times; <%= item.quantity %></td>
          </tr>
        <% end %>
      </table>
    </div>

    <div style="margin-top: 28px;">
      <a href="<%= delivery_order_url(@order) %>" class="btn">View Delivery Details &rarr;</a>
    </div>

    <p class="muted" style="margin-top: 20px;">Log in to the delivery portal to update the order status as you complete the delivery.</p>
  </div>

  <div class="footer">
    <p>Warehouse Furniture · 1104 E Veterans Memorial Blvd, Killeen, TX 76541</p>
    <p>© <%= Time.current.year %> Warehouse Furniture. All rights reserved.</p>
  </div>
</div>
