<div data-controller="drawer">
  <!-- Backdrop -->
  <div data-drawer-target="backdrop"
       data-action="click->drawer#close"
       class="fixed inset-0 z-40 bg-warm-950/50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
       aria-hidden="true"></div>

  <!-- Mobile drawer -->
  <nav data-drawer-target="panel"
       class="fixed top-0 left-0 z-50 h-full w-72 bg-warm-50 flex flex-col shadow-2xl -translate-x-full transition-transform duration-300 ease-in-out md:hidden"
       aria-modal="true" role="dialog" aria-label="Navigation menu">

    <div class="h-16 flex items-center justify-between px-5 border-b border-warm-400 flex-shrink-0">
      <%= link_to root_path, class: "text-base font-bold text-warm-900 tracking-tight", data: { action: "click->drawer#close" } do %>
        Warehouse Furniture
      <% end %>
      <button data-action="click->drawer#close"
              class="text-warm-400 hover:text-warm-700 p-1 rounded transition-colors"
              aria-label="Close menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto py-6 px-4 space-y-1">
      <%= link_to "Shop All", products_path,
          class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
          data: { action: "click->drawer#close" } %>
      <% Category.where(name: ["Living Room", "Bedroom", "Dining Room"]).order(Arel.sql("CASE name WHEN 'Living Room' THEN 0 WHEN 'Bedroom' THEN 1 WHEN 'Dining Room' THEN 2 END")).each do |category| %>
        <%= link_to category.name, category_path(category),
            class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
            data: { action: "click->drawer#close" } %>
      <% end %>

      <div class="pt-2 pb-1">
        <p class="px-3 py-1 text-xs font-semibold text-warm-400 uppercase tracking-widest">Brands</p>
      </div>
      <%= link_to "Ashley Furniture", brand_path("Ashley Furniture"),
          class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
          data: { action: "click->drawer#close" } %>
      <%= link_to "Generation Trade", brand_path("Generation Trade"),
          class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
          data: { action: "click->drawer#close" } %>

      <div class="border-t border-warm-400 pt-4 mt-4 space-y-1">
        <% if user_signed_in? %>
          <p class="px-3 py-1 text-xs font-semibold text-warm-400 uppercase tracking-widest"><%= current_user.full_name %></p>
          <%= link_to "My Account", account_profile_path,
              class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
              data: { action: "click->drawer#close" } %>
          <%= link_to "My Orders", account_orders_path,
              class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
              data: { action: "click->drawer#close" } %>
          <% if current_user.admin_or_above? %>
            <%= link_to "Admin Panel", admin_dashboard_path,
                class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-700 hover:bg-warm-200 rounded-lg transition-colors",
                data: { action: "click->drawer#close" } %>
          <% end %>
          <%= link_to "Sign Out", destroy_user_session_path,
              data: { turbo_method: :delete, action: "click->drawer#close" },
              class: "flex items-center px-3 py-2.5 text-sm text-warm-600 hover:bg-warm-200 rounded-lg transition-colors" %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path,
              class: "flex items-center px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
              data: { action: "click->drawer#close" } %>
          <%= link_to "Create Account", new_user_registration_path,
              class: "mt-2 block text-center text-sm font-semibold bg-warm-800 text-warm-50 px-4 py-3 rounded-full hover:bg-warm-700 transition-colors",
              data: { action: "click->drawer#close" } %>
        <% end %>
      </div>

      <!-- Cart in drawer -->
      <div class="border-t border-warm-400 pt-4 mt-2">
        <%= link_to cart_path,
            class: "flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-warm-800 hover:bg-warm-200 rounded-lg transition-colors",
            data: { action: "click->drawer#close" } do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          Cart
          <% count = current_cart.total_items %>
          <% if count > 0 %>
            <span class="ml-auto bg-warm-800 text-warm-50 text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
              <%= count %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <header class="bg-warm-50/95 backdrop-blur-sm border-b border-warm-200 sticky top-0 z-30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Mobile: hamburger left -->
        <button data-action="click->drawer#open"
                class="md:hidden p-2 text-warm-700 hover:bg-warm-200 rounded-lg transition-colors"
                aria-label="Open menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

        <!-- Logo — center on mobile, left on desktop -->
        <%= link_to root_path, class: "absolute left-1/2 -translate-x-1/2 md:static md:translate-x-0 flex items-center" do %>
          <span class="text-lg font-bold text-warm-900 tracking-tight whitespace-nowrap">Warehouse Furniture</span>
        <% end %>

        <!-- Desktop nav links -->
        <nav class="hidden md:flex items-center gap-7 ml-10">
          <%= link_to "Shop All", products_path, class: "nav-bubble text-sm text-warm-700 hover:text-warm-950" %>
          <% Category.where(name: ["Living Room", "Bedroom", "Dining Room"]).order(Arel.sql("CASE name WHEN 'Living Room' THEN 0 WHEN 'Bedroom' THEN 1 WHEN 'Dining Room' THEN 2 END")).each do |category| %>
            <%= link_to category.name, category_path(category), class: "nav-bubble text-sm text-warm-700 hover:text-warm-950" %>
          <% end %>
          <div class="relative" data-controller="dropdown">
            <button data-action="click->dropdown#toggle" class="nav-bubble flex items-center gap-1 text-sm text-warm-700 hover:text-warm-950">
              Brands
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute left-0 mt-2 w-44 bg-warm-50 rounded-xl shadow-lg border border-warm-400 py-1.5 z-50">
              <%= link_to "Ashley Furniture", brand_path("Ashley Furniture"), class: "block px-4 py-2 text-sm text-warm-800 hover:bg-warm-100" %>
              <%= link_to "Generation Trade", brand_path("Generation Trade"), class: "block px-4 py-2 text-sm text-warm-800 hover:bg-warm-100" %>
            </div>
          </div>
        </nav>

        <!-- Right icons -->
        <div class="flex items-center gap-4">
          <!-- Search (desktop only) -->
          <div class="hidden md:block">
            <%= link_to products_path, class: "nav-bubble text-warm-600 hover:text-warm-950" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            <% end %>
          </div>

          <!-- Cart -->
          <%= link_to cart_path, class: "nav-bubble relative text-warm-600 hover:text-warm-950" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <%= render "shared/cart_badge", count: current_cart.total_items %>
          <% end %>

          <!-- Auth (desktop) -->
          <div class="hidden md:block">
            <% if user_signed_in? %>
              <div class="relative" data-controller="dropdown">
                <button data-action="click->dropdown#toggle" class="nav-bubble flex items-center gap-1 text-sm text-warm-700 hover:text-warm-950">
                  <%= current_user.first_name %>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-warm-50 rounded-xl shadow-lg border border-warm-00 py-1.5 z-50">
                  <%= link_to "My Account", account_profile_path, class: "block px-4 py-2 text-sm text-warm-800 hover:bg-warm-100" %>
                  <%= link_to "My Orders", account_orders_path, class: "block px-4 py-2 text-sm text-warm-800 hover:bg-warm-100" %>
                  <% if current_user.admin_or_above? %>
                    <div class="border-t border-warm-400 my-1"></div>
                    <%= link_to "Admin Panel", admin_dashboard_path, class: "block px-4 py-2 text-sm text-warm-700 font-medium hover:bg-warm-100" %>
                  <% end %>
                  <div class="border-t border-warm-400 my-1"></div>
                  <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-4 py-2 text-sm text-warm-600 hover:bg-warm-100" %>
                </div>
              </div>
            <% else %>
              <%= link_to "Sign In", new_user_session_path, class: "nav-bubble text-sm text-warm-700 hover:text-warm-950" %>
              <%= link_to "Create Account", new_user_registration_path,
                  class: "hidden lg:inline-block ml-3 text-sm font-semibold bg-warm-800 text-warm-50 px-5 py-2 rounded-full hover:bg-warm-700 transition-colors" %>
            <% end %>
          </div>
        </div>

      </div>
    </div>
  </header>
</div>
