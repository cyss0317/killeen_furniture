<% announcements = active_announcements %>
<% if announcements.any? %>
  <div data-controller="announcement-modal"
       data-announcement-modal-items-value="<%= announcements.map { |a| { id: a.id, message: a.message } }.to_json %>">

    <dialog data-announcement-modal-target="dialog"
            class="bg-transparent m-auto p-0 w-full max-w-lg rounded-2xl
                   backdrop:bg-black/50 backdrop:backdrop-blur-sm">

      <div class="bg-white rounded-2xl shadow-2xl p-8 relative">

        <%# Close button %>
        <button type="button"
                data-action="click->announcement-modal#dismiss"
                class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors"
                aria-label="Close">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <%# Icon + title + counter %>
        <div class="flex items-center gap-3 mb-4">
          <div class="flex-shrink-0 w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
            </svg>
          </div>
          <div class="flex-1 flex items-center justify-between">
            <h2 class="text-lg font-bold text-gray-900">Announcement</h2>
            <div data-announcement-modal-target="nav"
                 class="hidden items-center gap-1">
              <button type="button"
                      data-announcement-modal-target="prev"
                      data-action="click->announcement-modal#prev"
                      class="p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-gray-600 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
                      aria-label="Previous">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>
              <span data-announcement-modal-target="counter"
                    class="text-xs text-gray-400 font-medium tabular-nums w-10 text-center"></span>
              <button type="button"
                      data-announcement-modal-target="next"
                      data-action="click->announcement-modal#next"
                      class="p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-gray-600 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
                      aria-label="Next">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <div data-announcement-modal-target="message"
             class="text-gray-700 text-sm leading-relaxed whitespace-pre-wrap break-words"></div>

        <div class="mt-6 flex items-center justify-between gap-4">
          <label class="flex items-center gap-2 text-sm text-gray-500 cursor-pointer select-none">
            <input type="checkbox"
                   data-announcement-modal-target="dontShowToday"
                   data-action="change->announcement-modal#checkboxChanged"
                   class="rounded border-gray-300 text-amber-700 focus:ring-amber-500">
            Don't show today
          </label>
          <button type="button"
                  data-action="click->announcement-modal#dismiss"
                  class="bg-amber-800 text-white text-sm font-semibold px-5 py-2 rounded-lg hover:bg-amber-900 transition-colors">
            Got it
          </button>
        </div>
      </div>
    </dialog>
  </div>
<% end %>
