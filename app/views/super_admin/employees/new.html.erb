<% content_for :title, "New Employee" %>

<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Back to Employees", super_admin_employees_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Employee</h1>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= render "shared/form_errors", object: @employee %>

    <%= form_with model: @employee, url: super_admin_employees_path, method: :post, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, required: true,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
        <div>
          <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, required: true,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email,
            placeholder: "email@example.com",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        <p class="text-xs text-gray-400 mt-1">Optional — leave blank if this employee doesn't have an email address.</p>
      </div>

      <div>
        <%= f.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.telephone_field :phone, placeholder: "(254) 555-0100",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :role,
              options_for_select([["Admin", "admin"], ["Super Admin", "super_admin"]], @employee.role),
              {},
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white" %>
        </div>
        <div>
          <%= f.label :admin_kind, "Kind", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :admin_kind,
              options_for_select([["None", ""], ["Ops", "ops"], ["Delivery", "delivery"]], @employee.admin_kind.to_s),
              {},
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :pay_type, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :pay_type,
              options_for_select([["None", ""], ["Hourly", "hourly"], ["Monthly", "monthly"]], @employee.pay_type.to_s),
              {},
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white" %>
        </div>
        <div>
          <%= f.label :pay_rate, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 text-sm pointer-events-none">$</span>
            <%= f.number_field :pay_rate, step: 0.01, min: 0, placeholder: "0.00",
                class: "w-full border border-gray-300 rounded-md pl-7 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <%= f.check_box :developer, class: "w-4 h-4 rounded border-gray-300 text-amber-700 focus:ring-amber-500 cursor-pointer" %>
        <%= f.label :developer, class: "text-sm font-medium text-gray-700" %>
      </div>

      <div class="flex gap-2 pt-2 border-t border-gray-100 mt-4">
        <%= f.submit "Add Employee", class: "px-4 py-2 text-sm rounded-md font-medium bg-amber-700 text-white hover:bg-amber-800 transition-colors cursor-pointer" %>
        <%= link_to "Cancel", super_admin_employees_path, class: "px-4 py-2 text-sm rounded-md font-medium border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
