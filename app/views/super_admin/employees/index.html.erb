<% content_for :title, "Employees" %>

<div data-controller="confirm-modal">

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-4">
    <h1 class="text-2xl font-bold text-gray-900">Employees</h1>
    <span class="text-sm text-gray-400"><%= @employees.size %> staff member<%= "s" if @employees.size != 1 %></span>
  </div>
  <%= link_to "+ New Employee", new_super_admin_employee_path,
      class: "px-4 py-1.5 text-sm rounded-md font-medium bg-amber-800 text-white hover:bg-amber-900 transition-colors" %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-100">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">First Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Last Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Email</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Phone</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Role</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Kind</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Pay Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Pay Rate</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase whitespace-nowrap">Dev</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @employees.each do |employee| %>
        <% form_id = "employee_form_#{employee.id}" %>
        <tr class="hover:bg-gray-50 align-middle" data-controller="save-button">
          <td class="hidden">
            <%= form_with model: employee, url: super_admin_employee_path(employee),
                 method: :patch, id: form_id,
                 data: { action: "turbo:submit-start->save-button#onStart turbo:submit-end->save-button#onEnd" } do %><% end %>
          </td>

          <%# First name %>
          <td class="px-4 py-3">
            <div class="flex flex-col gap-0.5">
              <%= text_field_tag "user[first_name]", employee.first_name,
                    form: form_id, required: true, placeholder: "First",
                    class: "w-32 text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500" %>
              <% if employee == current_user %>
                <span class="text-xs text-amber-600 font-medium">(you)</span>
              <% end %>
            </div>
          </td>

          <%# Last name %>
          <td class="px-4 py-3">
            <%= text_field_tag "user[last_name]", employee.last_name,
                  form: form_id, placeholder: "Last",
                  class: "w-32 text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </td>

          <%# Email — show blank if placeholder (no-email.local) %>
          <td class="px-4 py-3">
            <% display_email = employee.email.end_with?("@no-email.local") ? "" : employee.email %>
            <%= email_field_tag "user[email]", display_email,
                  form: form_id, placeholder: "email@example.com",
                  class: "w-44 text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </td>

          <%# Phone %>
          <td class="px-4 py-3">
            <%= telephone_field_tag "user[phone]", employee.phone,
                  form: form_id,
                  class: "w-36 text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500" %>
          </td>

          <td class="px-4 py-3">
            <%= select_tag "user[role]",
                  options_for_select([["Customer", "customer"], ["Admin", "admin"], ["Super Admin", "super_admin"]], employee.role),
                  form: form_id,
                  class: "text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white" %>
          </td>

          <td class="px-4 py-3">
            <%= select_tag "user[admin_kind]",
                  options_for_select([["None", ""], ["Ops", "ops"], ["Delivery", "delivery"]], employee.admin_kind.to_s),
                  form: form_id,
                  class: "text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white" %>
          </td>

          <td class="px-4 py-3">
            <%= select_tag "user[pay_type]",
                  options_for_select([["None", ""], ["Hourly", "hourly"], ["Monthly", "monthly"]], employee.pay_type.to_s),
                  form: form_id,
                  class: "text-sm border border-gray-300 rounded-md px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white" %>
          </td>

          <td class="px-4 py-3">
            <div class="relative w-28">
              <span class="absolute inset-y-0 left-0 pl-2 flex items-center text-gray-400 text-sm pointer-events-none">$</span>
              <%= number_field_tag "user[pay_rate]",
                    employee.pay_rate,
                    step: 0.01, min: 0,
                    form: form_id,
                    placeholder: "0.00",
                    class: "w-full text-sm border border-gray-300 rounded-md pl-6 pr-2 py-1.5 text-right focus:outline-none focus:ring-2 focus:ring-amber-500" %>
            </div>
          </td>

          <td class="px-4 py-3 text-center">
            <%= check_box_tag "user[developer]", "1", employee.developer?,
                form: form_id,
                class: "w-4 h-4 rounded border-gray-300 text-amber-700 focus:ring-amber-500 cursor-pointer" %>
          </td>

          <td class="px-4 py-3 whitespace-nowrap">
            <div class="flex items-center gap-2">
              <button type="submit" form="<%= form_id %>" data-save-button-target="btn"
                      class="inline-flex justify-center items-center text-sm px-3 py-1.5 bg-amber-700 text-white rounded-md hover:bg-amber-800 font-medium cursor-pointer transition-colors">
                Save
              </button>
              <button type="button"
                      data-action="click->confirm-modal#open"
                      data-confirm-modal-name-param="<%= employee.full_name %>"
                      data-confirm-modal-url-param="<%= super_admin_employee_path(employee) %>"
                      class="inline-flex justify-center items-center text-sm px-3 py-1.5 bg-white border border-red-300 text-red-600 rounded-md hover:bg-red-50 font-medium cursor-pointer transition-colors">
                Delete
              </button>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# ── Confirmation modal ── %>
<dialog data-confirm-modal-target="dialog"
        data-action="click->confirm-modal#backdropClick"
        class="rounded-xl shadow-2xl border border-gray-200 p-0 backdrop:bg-black/40 w-full max-w-md">
  <div class="p-6">
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      </div>
      <div>
        <h3 class="text-base font-semibold text-gray-900">Delete employee</h3>
        <p class="mt-1 text-sm text-gray-600">
          Are you sure you want to delete
          <span class="font-medium text-gray-900" data-confirm-modal-target="name"></span>?
          This action cannot be undone.
        </p>
      </div>
    </div>

    <div class="mt-6 flex justify-end gap-3">
      <button type="button" data-action="click->confirm-modal#cancel"
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors cursor-pointer">
        Cancel
      </button>
      <form data-confirm-modal-target="form" method="post">
        <input type="hidden" name="_method" value="delete">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button type="submit"
                class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-md hover:bg-red-700 transition-colors cursor-pointer">
          Delete
        </button>
      </form>
    </div>
  </div>
</dialog>

</div><%# /confirm-modal controller %>
