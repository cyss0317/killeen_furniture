<div class="container">
  <div class="header">
    <p class="header-wordmark">Warehouse Furniture</p>
    <p class="header-subtitle">Reset your password</p>
  </div>
  <div class="body">
    <p>Hi <%= @resource.first_name %>,</p>
    <p>We received a request to reset your password. Click the button below to choose a new one.</p>

    <div style="text-align: center; margin: 28px 0;">
      <%= link_to "Reset my password", edit_password_url(@resource, reset_password_token: @token), class: "btn" %>
    </div>

    <div class="info-box">
      <p>This link expires in 6 hours. If you didn't request a password reset, you can safely ignore this email — your password will not change.</p>
    </div>
  </div>
  <div class="footer">
    <p>Warehouse Furniture · 1104 E Veterans Memorial Blvd, Killeen, TX 76541</p>
    <p>© <%= Time.current.year %> Warehouse Furniture. All rights reserved.</p>
  </div>
</div>
