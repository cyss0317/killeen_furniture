<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-warm-950">Create an account</h1>
      <p class="mt-2 text-warm-700">Join us to track your orders and save your details</p>
    </div>

    <div class="bg-warm-50 rounded-2xl border border-warm-400 p-8">
      <%# OAuth providers %>
      <div class="space-y-3 mb-6">
        <%= button_to user_google_oauth2_omniauth_authorize_path,
            data: { turbo: false },
            class: "w-full flex items-center justify-center gap-3 bg-white border border-warm-400 text-warm-900 font-medium py-2.5 px-4 rounded-xl hover:bg-warm-100 transition-colors text-sm cursor-pointer" do %>
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        <% end %>

      </div>

      <div class="flex items-center gap-3 mb-6">
        <div class="flex-1 h-px bg-warm-300"></div>
        <span class="text-xs text-warm-400 font-medium">or create account with email</span>
        <div class="flex-1 h-px bg-warm-300"></div>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
            data: { controller: "signup-guard" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%# Honeypot — hidden from humans via CSS; bots fill it and get silently rejected %>
        <div class="absolute opacity-0 top-0 left-0 w-0 h-0 overflow-hidden" aria-hidden="true" tabindex="-1">
          <label for="user_website">Website</label>
          <%= text_field_tag :website, nil, autocomplete: "off", tabindex: -1, id: "user_website", name: "user[website]" %>
        </div>

        <div class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :first_name, class: "block text-sm font-medium text-warm-800 mb-1" %>
              <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
                  data: { "signup-guard-target": "firstName" },
                  class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                  placeholder: "Jane" %>
              <p data-signup-guard-target="firstNameError" class="hidden mt-1 text-xs text-red-600"></p>
            </div>
            <div>
              <%= f.label :last_name, class: "block text-sm font-medium text-warm-800 mb-1" %>
              <%= f.text_field :last_name, autocomplete: "family-name",
                  data: { "signup-guard-target": "lastName" },
                  class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                  placeholder: "Smith" %>
              <p data-signup-guard-target="lastNameError" class="hidden mt-1 text-xs text-red-600"></p>
            </div>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-warm-800 mb-1" %>
            <%= f.email_field :email, autocomplete: "email",
                data: { "signup-guard-target": "email" },
                class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                placeholder: "you@example.com" %>
            <p data-signup-guard-target="emailError" class="hidden mt-1 text-xs text-red-600"></p>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <%= f.label :password, class: "block text-sm font-medium text-warm-800" %>
              <% if @minimum_password_length %>
                <span class="text-xs text-warm-400"><%= @minimum_password_length %> characters minimum</span>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                placeholder: "••••••••" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-warm-800 mb-1" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                placeholder: "••••••••" %>
          </div>

          <%= f.submit "Create account", class: "w-full bg-warm-800 hover:bg-warm-700 text-warm-50 font-semibold py-3 px-6 rounded-full transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
