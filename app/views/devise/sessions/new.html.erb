<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-warm-950">Welcome back</h1>
      <p class="mt-2 text-warm-700">Sign in to your account</p>
    </div>

    <div class="bg-warm-50 rounded-2xl border border-warm-400 p-8">
      <%# OAuth providers %>
      <div class="space-y-3 mb-6">
        <%= button_to user_google_oauth2_omniauth_authorize_path,
            data: { turbo: false },
            class: "w-full flex items-center justify-center gap-3 bg-white border border-warm-400 text-warm-900 font-medium py-2.5 px-4 rounded-xl hover:bg-warm-100 transition-colors text-sm cursor-pointer" do %>
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        <% end %>

      </div>

      <div class="flex items-center gap-3 mb-6">
        <div class="flex-1 h-px bg-warm-300"></div>
        <span class="text-xs text-warm-400 font-medium">or sign in with email</span>
        <div class="flex-1 h-px bg-warm-300"></div>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-5">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-warm-800 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                placeholder: "you@example.com" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-warm-800 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                placeholder: "••••••••" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "w-4 h-4 accent-warm-700 border-warm-400 rounded" %>
              <%= f.label :remember_me, class: "ml-2 text-sm text-warm-600" %>
            </div>
          <% end %>

          <%= f.submit "Sign in", class: "w-full bg-warm-800 hover:bg-warm-700 text-warm-50 font-semibold py-3 px-6 rounded-full transition-colors cursor-pointer mt-2" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>

    <% if Rails.env.development? %>
      <div class="mt-6 p-4 bg-warm-100 border border-warm-400 rounded-xl">
        <p class="text-xs font-semibold text-warm-600 uppercase tracking-wide mb-3">Dev Quick Login</p>
        <div class="flex flex-col gap-2">
          <button type="button"
                  onclick="quickLogin('cyss0317@gmail.com', 'asdfasdf')"
                  class="w-full text-sm font-medium bg-white border border-warm-400 text-warm-800 py-2 px-4 rounded-lg hover:bg-warm-200 transition-colors text-left">
            Login as Admin (cyss0317@gmail.com)
          </button>
          <button type="button"
                  onclick="quickLogin('delivery@gmail.com', 'asdfasdf')"
                  class="w-full text-sm font-medium bg-white border border-warm-400 text-warm-800 py-2 px-4 rounded-lg hover:bg-warm-200 transition-colors text-left">
            Login as Delivery (delivery@gmail.com)
          </button>
        </div>
      </div>
      <script>
        function quickLogin(email, password) {
          document.querySelector('input[type="email"]').value = email;
          document.querySelector('input[type="password"]').value = password;
          document.querySelector('input[type="submit"]').click();
        }
      </script>
    <% end %>
  </div>
</div>
