<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-warm-950">Resend Confirmation</h1>
      <p class="mt-2 text-warm-700">Enter your email and we'll resend your confirmation instructions.</p>
    </div>

    <div class="bg-warm-50 rounded-2xl border border-warm-400 p-8">
      <%= form_for(resource, as: resource_name, url: user_confirmation_path, html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-5">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-warm-800 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                class: "w-full px-4 py-2.5 border border-warm-400 rounded-xl bg-white text-warm-900 placeholder-warm-300 focus:outline-none focus:ring-2 focus:ring-warm-400 focus:border-transparent",
                placeholder: "you@example.com" %>
          </div>

          <%= f.submit "Resend confirmation instructions",
              class: "w-full bg-warm-800 hover:bg-warm-700 text-warm-50 font-semibold py-3 px-6 rounded-full transition-colors cursor-pointer mt-2" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
